---
import { nav, business } from "../data/site";
import Icon from "./Icon.astro";
import Button from "./Button.astro";
---

<header class="sticky top-0 z-50 border-b border-forest-100 bg-cream/90 backdrop-blur">
  <!-- Utility bar -->
  <div class="hidden bg-forest-800 text-cream lg:block">
    <div class="container-page flex h-9 items-center justify-between text-xs">
      <span>{business.tagline}</span>
      <div class="flex items-center gap-5">
        <span>Serving Norristown &amp; the Main Line</span>
        <a href={business.phoneHref} class="inline-flex items-center gap-1.5 font-medium hover:text-clay-300">
          <Icon name="phone" class="h-3.5 w-3.5" />
          {business.phoneDisplay}
        </a>
      </div>
    </div>
  </div>

  <div class="container-page flex h-16 items-center justify-between gap-4">
    <a href="/" aria-label="Mex Landscaping home" class="inline-flex items-center gap-2">
      <span class="grid h-9 w-9 place-items-center rounded-full bg-forest-700 text-cream">
        <Icon name="leaf" class="h-5 w-5" />
      </span>
      <span class="font-[Fraunces] text-xl font-semibold tracking-tight" style="font-family:var(--font-display)">
        Mex<span class="text-leaf-500">Landscaping</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-0.5 xl:flex">
      {
        nav.map((item) =>
          item.children ? (
            <div class="group relative">
              <a
                href={item.href}
                class="inline-flex items-center gap-1 rounded-full px-3 py-2 text-sm font-medium text-forest-800 hover:bg-forest-50"
              >
                {item.label}
                <Icon name="chevron" class="h-3.5 w-3.5 opacity-70" />
              </a>
              <div class="invisible absolute left-0 top-full w-72 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100">
                <div class="overflow-hidden rounded-2xl border border-forest-100 bg-white p-2 shadow-xl shadow-forest-900/10">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-xl px-3 py-2 text-sm text-forest-700 hover:bg-forest-50"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="rounded-full px-3 py-2 text-sm font-medium text-forest-800 hover:bg-forest-50"
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="hidden xl:block">
      <Button href="/contact-us/">Free Estimate</Button>
    </div>

    <button
      type="button"
      id="menu-toggle"
      class="grid h-10 w-10 place-items-center rounded-full text-forest-800 hover:bg-forest-50 xl:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span id="menu-open"><Icon name="menu" class="h-6 w-6" /></span>
      <span id="menu-close" class="hidden"><Icon name="close" class="h-6 w-6" /></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-forest-100 bg-cream xl:hidden">
    <nav class="container-page max-h-[calc(100vh-4rem)] space-y-1 overflow-y-auto py-4">
      {
        nav.map((item) =>
          item.children ? (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-xl px-3 py-2.5 text-base font-semibold text-forest-800 hover:bg-forest-50">
                {item.label}
                <Icon name="chevron" class="h-4 w-4 transition-transform group-open:rotate-180" />
              </summary>
              <div class="ml-3 border-l border-forest-100 pl-3">
                {item.children.map((child) => (
                  <a href={child.href} class="block rounded-lg px-3 py-2 text-sm text-forest-600">
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.href} class="block rounded-xl px-3 py-2.5 text-base font-semibold text-forest-800 hover:bg-forest-50">
              {item.label}
            </a>
          )
        )
      }
      <div class="pt-3">
        <Button href="/contact-us/" size="lg" class="w-full">Get a Free Estimate</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const openIcon = document.getElementById("menu-open");
  const closeIcon = document.getElementById("menu-close");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    openIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  });
</script>
