---
import { nav, business } from "../data/site";
import Icon from "./Icon.astro";
import Button from "./Button.astro";
---

<header class="sticky top-0 z-50 border-b border-forest-100 bg-white shadow-sm">
  <div class="container-page flex h-20 items-center justify-between gap-4">
    <a href="/" aria-label="Mex Landscaping home" class="inline-flex shrink-0 items-center">
      <img
        src="/images/mex-landscaping-logo.png"
        alt="Mex Landscaping"
        width="358"
        height="255"
        class="h-14 w-auto"
      />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-0.5 xl:flex">
      {
        nav.map((item) =>
          item.children ? (
            <div class="group relative">
              <a
                href={item.href}
                class="inline-flex items-center gap-1 whitespace-nowrap rounded-md px-2.5 py-2 text-[15px] font-medium text-ink-800 hover:text-leaf-600"
              >
                {item.label}
                <Icon name="chevron" class="h-3.5 w-3.5 opacity-70" />
              </a>
              <div class="invisible absolute left-0 top-full w-72 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100">
                <div class="overflow-hidden rounded-xl border border-forest-100 bg-white p-2 shadow-xl shadow-ink-950/20">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block rounded-lg px-3 py-2 text-sm font-medium text-forest-700 hover:bg-sand hover:text-leaf-600"
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class="whitespace-nowrap rounded-md px-2.5 py-2 text-[15px] font-medium text-ink-800 hover:text-leaf-600"
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="hidden shrink-0 items-center gap-2 xl:flex">
      <a
        href={business.phoneHref}
        class="inline-flex items-center gap-1.5 rounded-lg px-2.5 py-2.5 text-sm font-bold text-ink-900 transition hover:text-leaf-600"
      >
        <Icon name="phone" class="h-4 w-4 text-leaf-500" />
        {business.phoneDisplay}
      </a>
      <Button href="/contact-us/">Free Estimate</Button>
    </div>

    <button
      type="button"
      id="menu-toggle"
      class="grid h-10 w-10 place-items-center rounded-lg text-ink-900 hover:bg-forest-50 xl:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span id="menu-open"><Icon name="menu" class="h-6 w-6" /></span>
      <span id="menu-close" class="hidden"><Icon name="close" class="h-6 w-6" /></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-forest-100 bg-white xl:hidden">
    <nav class="container-page max-h-[calc(100vh-5rem)] space-y-1 overflow-y-auto py-4">
      {
        nav.map((item) =>
          item.children ? (
            <details class="group">
              <summary class="flex cursor-pointer list-none items-center justify-between rounded-lg px-3 py-2.5 text-base font-semibold text-ink-900 hover:bg-forest-50">
                {item.label}
                <Icon name="chevron" class="h-4 w-4 transition-transform group-open:rotate-180" />
              </summary>
              <div class="ml-3 border-l border-forest-200 pl-3">
                {item.children.map((child) => (
                  <a href={child.href} class="block rounded-lg px-3 py-2 text-sm text-forest-700 hover:text-leaf-600">
                    {child.label}
                  </a>
                ))}
              </div>
            </details>
          ) : (
            <a href={item.href} class="block rounded-lg px-3 py-2.5 text-base font-semibold text-ink-900 hover:bg-forest-50">
              {item.label}
            </a>
          )
        )
      }
      <div class="space-y-3 pt-3">
        <a
          href={business.phoneHref}
          class="flex items-center justify-center gap-2 rounded-lg border border-forest-200 px-4 py-3 font-bold text-ink-900"
        >
          <Icon name="phone" class="h-4 w-4 text-leaf-500" />
          {business.phoneDisplay}
        </a>
        <Button href="/contact-us/" size="lg" class="w-full">Get a Free Estimate</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const openIcon = document.getElementById("menu-open");
  const closeIcon = document.getElementById("menu-close");
  toggle?.addEventListener("click", () => {
    const isOpen = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(isOpen));
    openIcon?.classList.toggle("hidden", isOpen);
    closeIcon?.classList.toggle("hidden", !isOpen);
  });
</script>
