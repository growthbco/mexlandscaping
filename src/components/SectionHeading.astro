---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  center?: boolean;
  /** Set when rendered on a dark background */
  dark?: boolean;
}
const { eyebrow, title, intro, center = false, dark = false } = Astro.props;
---

<div class={`max-w-2xl ${center ? "mx-auto text-center" : ""}`}>
  {
    eyebrow && (
      <span class={`block text-sm font-semibold uppercase tracking-eyebrow ${dark ? "text-gold-300" : "text-forest-500"}`}>
        {eyebrow}
      </span>
    )
  }
  <h2 class={`mt-3 font-display text-4xl font-semibold leading-[1.05] sm:text-5xl ${dark ? "text-white" : "text-forest-900"}`}>
    {title}
  </h2>
  {intro && <p class={`mt-4 text-lg leading-relaxed ${dark ? "text-white/75" : "text-forest-600"}`}>{intro}</p>}
</div>
