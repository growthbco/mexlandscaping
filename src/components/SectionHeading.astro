---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  center?: boolean;
}
const { eyebrow, title, intro, center = false } = Astro.props;
---

<div class={`max-w-2xl ${center ? "mx-auto text-center" : ""}`}>
  {
    eyebrow && (
      <span class={`inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-leaf-600 ${center ? "justify-center" : ""}`}>
        <span class="h-px w-6 bg-leaf-500"></span>
        {eyebrow}
      </span>
    )
  }
  <h2 class="mt-3 text-3xl font-semibold leading-tight text-forest-900 sm:text-4xl" style="font-family:var(--font-display)">
    {title}
  </h2>
  {intro && <p class="mt-4 text-lg leading-relaxed text-forest-700/90">{intro}</p>}
</div>
