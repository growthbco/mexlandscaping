---
import { whyUs, business } from "../data/site";
import Section from "./Section.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
---

<Section>
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <span class="block text-sm font-semibold uppercase tracking-eyebrow text-forest-500">Why choose us</span>
      <h2 class="mt-3 font-display text-4xl font-semibold leading-[1.05] text-forest-900 sm:text-5xl">
        Your trusted landscaping partner
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-forest-600">
        Mex Landscaping has been transforming outdoor spaces across Norristown
        and the Main Line. We combine quality craftsmanship with reliable
        service to deliver results that exceed expectations.
      </p>
      <ul class="mt-8 space-y-5">
        {
          whyUs.map((item) => (
            <li class="flex gap-3.5">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-clay-400 text-white">
                <Icon name="check" class="h-3.5 w-3.5" />
              </span>
              <span>
                <span class="block font-display text-base font-semibold tracking-wide text-forest-900">{item.title}</span>
                <span class="mt-0.5 block text-forest-600">{item.body}</span>
              </span>
            </li>
          ))
        }
      </ul>
      <div class="mt-9">
        <Button href="/about-us/" size="lg">Learn About Us</Button>
      </div>
    </div>
    <div class="relative">
      <img
        src="/images/landscape-design.webp"
        alt="Landscaped front yard designed and built by Mex Landscaping"
        class="w-full rounded-2xl object-cover shadow-xl shadow-ink-950/10"
        loading="lazy"
      />
      <div class="absolute -bottom-8 left-6 w-64 rounded-2xl bg-white p-6 shadow-xl shadow-ink-950/15 sm:left-10">
        <div class="flex items-center gap-4">
          <span class="grid h-12 w-12 place-items-center rounded-full bg-clay-400/15 text-clay-400">
            <Icon name="star" class="h-6 w-6" />
          </span>
          <span>
            <span class="block font-display text-3xl font-semibold text-forest-900">4.9</span>
            <span class="text-sm text-forest-500">on Google</span>
          </span>
        </div>
        <div class="mt-3 flex gap-0.5 text-clay-400">
          {[0, 1, 2, 3, 4].map(() => <Icon name="star" class="h-5 w-5" />)}
        </div>
        <p class="mt-2 text-sm text-forest-600">
          From 30+ homeowner reviews.
          <a href={business.social.google} target="_blank" rel="noopener" class="font-semibold text-leaf-600 hover:text-leaf-500">Read them →</a>
        </p>
      </div>
    </div>
  </div>
</Section>
