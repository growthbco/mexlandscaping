---
import { whyUs } from "../data/site";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
---

<Section>
  <div class="grid gap-12 lg:grid-cols-2 lg:items-center">
    <div>
      <SectionHeading
        eyebrow="Why Mex Landscaping"
        title="Quality and reliability, season after season"
        intro="Your time is valuable. Trust us to handle the hard work so you can enjoy a beautiful, season-ready property without the hassle."
      />
      <div class="mt-8">
        <Button href="/about-us/" variant="outline">More about us</Button>
      </div>
    </div>
    <div class="grid gap-5 sm:grid-cols-2">
      {
        whyUs.map((item) => (
          <div class="rounded-2xl border border-forest-100 bg-white p-6">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-leaf-500/15 text-leaf-600">
              <Icon name="check" class="h-5 w-5" />
            </span>
            <h3 class="mt-4 font-semibold text-forest-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-forest-700/90">{item.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</Section>
