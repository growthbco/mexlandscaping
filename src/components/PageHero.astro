---
import Icon from "./Icon.astro";

export interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  crumbs?: Crumb[];
}
const { eyebrow, title, intro, crumbs } = Astro.props;
---

<section class="relative overflow-hidden bg-forest-900 text-cream">
  <div
    class="pointer-events-none absolute inset-0 opacity-90"
    style="background: radial-gradient(100% 80% at 90% -20%, #316038 0%, transparent 55%)"
  >
  </div>
  <div class="container-page relative py-16 lg:py-20">
    {
      crumbs && (
        <nav class="mb-5 text-sm text-forest-300" aria-label="Breadcrumb">
          <ol class="flex flex-wrap items-center gap-1.5">
            {crumbs.map((crumb, i) => (
              <li class="flex items-center gap-1.5">
                {crumb.href ? (
                  <a href={crumb.href} class="hover:text-clay-300">{crumb.label}</a>
                ) : (
                  <span class="text-cream">{crumb.label}</span>
                )}
                {i < crumbs.length - 1 && <span class="text-forest-600">/</span>}
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    {
      eyebrow && (
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-leaf-400">
          <span class="h-px w-6 bg-leaf-500" />
          {eyebrow}
        </span>
      )
    }
    <h1 class="mt-3 max-w-3xl text-4xl font-semibold leading-tight sm:text-5xl" style="font-family:var(--font-display)">
      {title}
    </h1>
    {intro && <p class="mt-5 max-w-2xl text-lg text-forest-200">{intro}</p>}
  </div>
</section>
