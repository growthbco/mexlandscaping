---
interface Props {
  href: string;
  variant?: "primary" | "secondary" | "outline" | "outline-light";
  size?: "md" | "lg";
  class?: string;
}
const { href, variant = "primary", size = "md", class: className = "" } = Astro.props;

const variants: Record<string, string> = {
  primary: "bg-clay-500 text-white hover:bg-clay-600 shadow-sm shadow-clay-600/20",
  secondary: "bg-forest-700 text-cream hover:bg-forest-800",
  outline: "border border-forest-300 text-forest-800 hover:bg-forest-50",
  "outline-light": "border border-forest-500 text-cream hover:bg-forest-800",
};
const sizes: Record<string, string> = {
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-base",
};
const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-forest-600";
---

<a href={href} class={`${base} ${variants[variant]} ${sizes[size]} ${className}`}>
  <slot />
</a>
