---
import type { LocationPage } from "../../data/locations";
import { locationContent, designPath, snowPath } from "../../data/locations";
import { cities } from "../../data/site";
import PageHero from "../PageHero.astro";
import Section from "../Section.astro";
import LeadForm from "../LeadForm.astro";
import CtaBanner from "../CtaBanner.astro";
import Icon from "../Icon.astro";

interface Props {
  page: LocationPage;
}
const { page } = Astro.props;
const c = locationContent(page);
const isDesign = page.kind === "design";
const otherKindHref = isDesign ? snowPath(page.city.slug) : designPath(page.city.slug);
const otherKindLabel = isDesign
  ? `Snow Management in ${page.city.name}`
  : `Landscape Design & Hardscaping in ${page.city.name}`;
const buildHref = isDesign ? designPath : snowPath;
const nearby = cities.filter((x) => x.slug !== page.city.slug).slice(0, 8);
---

<PageHero
  eyebrow={`${c.crumb} · ${page.city.name}, PA`}
  title={c.h1}
  intro={c.intro}
  image={c.image}
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Service Areas", href: "/service-areas/" },
    { label: `${page.city.name}, PA` },
  ]}
/>

<Section>
  <div class="grid gap-12 lg:grid-cols-3">
    <div class="lg:col-span-2">
      {
        c.body.map((b) => (
          <div class="mb-8">
            <h2 class="font-display text-2xl font-semibold text-forest-900">{b.heading}</h2>
            <p class="mt-3 text-lg leading-relaxed text-forest-800">{b.text}</p>
          </div>
        ))
      }

      <ul class="mt-2 grid gap-3 sm:grid-cols-2">
        {
          c.highlights.map((h) => (
            <li class="flex items-start gap-3 rounded-2xl border border-forest-100 bg-white p-4">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-leaf-500/15 text-leaf-600">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <span class="text-sm text-forest-800">{h}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-8 rounded-2xl bg-forest-50 p-5 text-forest-800">
        <strong>{c.cta}</strong>
      </div>

      <div class="mt-8">
        <a href={otherKindHref} class="font-semibold text-forest-700 hover:text-clay-600">
          Also need {otherKindLabel}? →
        </a>
      </div>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div>
          <h2 class="font-display text-xl font-semibold text-forest-900">Free local estimate</h2>
          <p class="mt-2 text-sm text-forest-700">Serving {page.city.name} and nearby with fast response.</p>
          <div class="mt-4">
            <LeadForm defaultService={`${c.crumb}: ${page.city.name}, PA`} compact />
          </div>
        </div>

        <div class="rounded-3xl border border-forest-100 bg-white p-7">
          <h3 class="font-semibold text-forest-900">Nearby areas</h3>
          <ul class="mt-4 grid grid-cols-2 gap-x-3 gap-y-1 text-sm">
            {
              nearby.map((x) => (
                <li>
                  <a href={buildHref(x.slug)} class="text-forest-700 hover:text-clay-600">{x.name}</a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </aside>
  </div>
</Section>

<CtaBanner title={`Serving ${page.city.name}, PA`} />
