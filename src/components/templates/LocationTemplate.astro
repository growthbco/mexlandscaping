---
import type { LocationPage } from "../../data/locations";
import { locationContent, designPath, snowPath } from "../../data/locations";
import { cities } from "../../data/site";
import PageHero from "../PageHero.astro";
import Section from "../Section.astro";
import LeadForm from "../LeadForm.astro";
import CtaBanner from "../CtaBanner.astro";
import Icon from "../Icon.astro";

interface Props {
  page: LocationPage;
}
const { page } = Astro.props;
const c = locationContent(page);
const isDesign = page.kind === "design";
const otherKindHref = isDesign ? snowPath(page.city.slug) : designPath(page.city.slug);
const otherKindLabel = isDesign
  ? `Snow Management in ${page.city.name}`
  : `Landscape Design & Hardscaping in ${page.city.name}`;
const buildHref = isDesign ? designPath : snowPath;
const nearby = cities.filter((x) => x.slug !== page.city.slug).slice(0, 8);

// Internal links from this city page to the relevant service pages.
const designServices = [
  { label: "Landscape Design & Build", href: "/landscape-design/" },
  { label: "Patios", href: "/patios/" },
  { label: "Walkways & Steps", href: "/walkways/" },
  { label: "Driveways", href: "/driveways/" },
  { label: "Retaining & Seating Walls", href: "/retaining-walls/" },
  { label: "Outdoor Living", href: "/outdoor-living/" },
  { label: "Fire Pits & Fire Features", href: "/fire-pits/" },
  { label: "Outdoor Kitchens", href: "/outdoor-kitchens/" },
  { label: "Split Rail Fencing", href: "/split-rail-fencing/" },
  { label: "Outdoor Concrete & Masonry", href: "/concrete-masonry/" },
  { label: "Landscape Lighting", href: "/landscape-lighting/" },
];
const snowServices = [
  { label: "Commercial Snow Management", href: "/snow-management-services/" },
  { label: "Commercial Snow Plowing", href: "/commercial-snow-plowing/" },
  { label: "24/7 Emergency Snow", href: "/24-7-emergency-snow-services/" },
  { label: "Sidewalk Snow Removal", href: "/sidewalk-snow-removal/" },
  { label: "Salting & De-Icing", href: "/salting-de-icing/" },
];
const cityServices = isDesign ? designServices : snowServices;
---

<PageHero
  eyebrow={`${c.crumb} · ${page.city.name}, PA`}
  title={c.h1}
  intro={c.intro}
  image={c.image}
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Service Areas", href: "/service-areas/" },
    { label: `${page.city.name}, PA` },
  ]}
/>

<Section>
  <div class="grid gap-12 lg:grid-cols-3">
    <div class="lg:col-span-2">
      {
        c.body.map((b) => (
          <div class="mb-8">
            <h2 class="font-display text-2xl font-semibold text-forest-900">{b.heading}</h2>
            <p class="body-copy mt-3 text-lg leading-relaxed text-forest-800" set:html={b.text} />
          </div>
        ))
      }

      {
        c.gallery && c.gallery.length > 0 && (
          <div class="mb-10">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              Recent work by Mex Landscaping
            </h2>
            <div class="mt-5 grid gap-4 sm:grid-cols-3">
              {c.gallery.map((g) => (
                <figure class="overflow-hidden rounded-2xl border border-forest-100 bg-white">
                  <img
                    src={g.src}
                    alt={g.alt}
                    loading="lazy"
                    decoding="async"
                    class="aspect-[4/3] w-full object-cover"
                  />
                  <figcaption class="px-4 py-3 text-sm text-forest-700">{g.caption}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        )
      }

      <ul class="mt-2 grid gap-3 sm:grid-cols-2">
        {
          c.highlights.map((h) => (
            <li class="flex items-start gap-3 rounded-2xl border border-forest-100 bg-white p-4">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-leaf-500/15 text-leaf-600">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <span class="text-sm text-forest-800">{h}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-12">
        <h2 class="font-display text-2xl font-semibold text-forest-900">
          Services we offer in {page.city.name}
        </h2>
        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            cityServices.map((s) => (
              <a
                href={s.href}
                class="group flex items-center justify-between rounded-2xl border border-forest-100 bg-white px-5 py-3.5 text-forest-800 transition hover:border-leaf-500/40 hover:bg-forest-50"
              >
                <span class="font-medium">{s.label}</span>
                <Icon name="arrow" class="h-4 w-4 shrink-0 text-forest-300 transition-transform group-hover:translate-x-0.5 group-hover:text-leaf-600" />
              </a>
            ))
          }
        </div>
      </div>

      {
        c.faqs && c.faqs.length > 0 && (
          <div class="mt-14">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              {page.city.name} landscaping FAQs
            </h2>
            <div class="mt-5 space-y-3">
              {c.faqs.map((f) => (
                <details class="group rounded-2xl border border-forest-100 bg-white p-5 open:shadow-sm">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-forest-900">
                    {f.q}
                    <Icon name="chevron" class="h-5 w-5 shrink-0 text-forest-400 transition-transform group-open:rotate-180" />
                  </summary>
                  <p class="mt-3 leading-relaxed text-forest-700">{f.a}</p>
                </details>
              ))}
            </div>
          </div>
        )
      }

      <div class="mt-8 rounded-2xl bg-forest-50 p-5 text-forest-800">
        <strong>{c.cta}</strong>
      </div>

      <div class="mt-8">
        <a href={otherKindHref} class="font-semibold text-forest-700 hover:text-clay-600">
          Also need {otherKindLabel}? →
        </a>
      </div>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div>
          <h2 class="font-display text-xl font-semibold text-forest-900">Free local estimate</h2>
          <p class="mt-2 text-sm text-forest-700">Serving {page.city.name} and nearby with fast response.</p>
          <div class="mt-4">
            <LeadForm defaultService={`${c.crumb}: ${page.city.name}, PA`} compact />
          </div>
        </div>

        <div class="rounded-3xl border border-forest-100 bg-white p-7">
          <h3 class="font-semibold text-forest-900">Nearby areas</h3>
          <ul class="mt-4 grid grid-cols-2 gap-x-3 gap-y-1 text-sm">
            {
              nearby.map((x) => (
                <li>
                  <a href={buildHref(x.slug)} class="text-forest-700 hover:text-clay-600">{x.name}</a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </aside>
  </div>
</Section>

<CtaBanner title={`Serving ${page.city.name}, PA`} />

<style>
  /* In-body contextual internal links (authored in src/data/locations.ts).
     set:html content isn't reached by Astro's scoped selectors, so :global. */
  .body-copy :global(a) {
    font-weight: 600;
    color: var(--color-leaf-600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .body-copy :global(a:hover) {
    color: var(--color-leaf-500);
  }
</style>
