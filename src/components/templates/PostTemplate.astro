---
import type { Post } from "../../data/posts";
import { posts as allPosts } from "../../data/posts";
import PageHero from "../PageHero.astro";
import Section from "../Section.astro";
import CtaBanner from "../CtaBanner.astro";
import Icon from "../Icon.astro";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const dateLabel = post.date
  ? new Date(post.date).toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
const more = allPosts.filter((p) => p.slug !== post.slug).slice(0, 2);
---

<PageHero
  eyebrow={dateLabel}
  title={post.title}
  crumbs={[
    { label: "Home", href: "/" },
    { label: "Blog", href: "/blog/" },
    { label: post.title },
  ]}
/>

<Section>
  <div class="mx-auto max-w-2xl">
    <div class="prose-mex">
      {post.paragraphs.map((para) => <p>{para}</p>)}
    </div>

    <div class="mt-10 border-t border-forest-100 pt-6">
      <a href="/blog/" class="inline-flex items-center gap-1.5 font-semibold text-forest-700 hover:text-clay-600">
        <Icon name="arrow" class="h-4 w-4 rotate-180" />Back to all posts
      </a>
    </div>

    {
      more.length > 0 && (
        <div class="mt-12">
          <h2 class="font-display text-xl font-semibold text-forest-900">
            Keep reading
          </h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {more.map((p) => (
              <a href={`/${p.slug}/`} class="group rounded-2xl border border-forest-100 bg-white p-5 hover:shadow-md">
                <h3 class="font-semibold text-forest-900 group-hover:text-clay-600">{p.title}</h3>
              </a>
            ))}
          </div>
        </div>
      )
    }
  </div>
</Section>

<CtaBanner />
