---
import type { Service } from "../../data/services";
import { categoryLabels, categoryHubs, servicesByCategory, premiumCategories } from "../../data/services";
import { seoFor } from "../../data/seo.generated";
import { cities } from "../../data/site";
import { designPath, snowPath } from "../../data/locations";
import PageHero from "../PageHero.astro";
import Section from "../Section.astro";
import LeadForm from "../LeadForm.astro";
import CtaBanner from "../CtaBanner.astro";
import ProcessSteps from "../ProcessSteps.astro";
import Icon from "../Icon.astro";

interface Props {
  service: Service;
}
const { service } = Astro.props;
const meta = seoFor(service.path);
const h1 = meta?.h1 && meta.h1.length ? meta.h1 : service.title;
const catLabel = categoryLabels[service.category];
const hub = categoryHubs[service.category];
const related = servicesByCategory(service.category)
  .filter((s) => s.path !== service.path)
  .slice(0, 5);

// Internal links: service page -> the city pages where we offer it.
const areaPath = service.category === "snow" ? snowPath : designPath;
const areaCities = cities.slice(0, 12);
// Cross-category links to the other main service hubs.
const otherCats = premiumCategories
  .filter((cat) => cat !== service.category)
  .map((cat) => ({ label: categoryLabels[cat], href: categoryHubs[cat] }));
---

<PageHero
  eyebrow={catLabel}
  title={h1}
  intro={service.intro}
  image={service.image}
  crumbs={[
    { label: "Home", href: "/" },
    { label: catLabel, href: hub },
    { label: service.title },
  ]}
/>

<Section>
  <div class="grid gap-12 lg:grid-cols-3">
    <div class="lg:col-span-2">
      {
        service.body.map((b) => (
          <div class="mb-8">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              {b.heading}
            </h2>
            <p class="body-copy mt-3 text-lg leading-relaxed text-forest-800" set:html={b.text} />
          </div>
        ))
      }

      {
        service.gallery && service.gallery.length > 0 && (
          <div class="mb-10">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              Recent work by Mex Landscaping
            </h2>
            <div class="mt-5 grid gap-4 sm:grid-cols-3">
              {service.gallery.map((g) => (
                <figure class="overflow-hidden rounded-2xl border border-forest-100 bg-white">
                  <img
                    src={g.src}
                    alt={g.alt}
                    loading="lazy"
                    decoding="async"
                    class="aspect-[4/3] w-full object-cover"
                  />
                  <figcaption class="px-4 py-3 text-sm text-forest-700">{g.caption}</figcaption>
                </figure>
              ))}
            </div>
            <p class="mt-4 text-sm text-forest-600">
              See more on <a href="/our-work/" class="font-semibold text-leaf-600 hover:text-leaf-500">Our Work</a> and in our <a href="/projects/" class="font-semibold text-leaf-600 hover:text-leaf-500">project case studies</a>.
            </p>
          </div>
        )
      }

      <h2 class="font-display mt-2 text-2xl font-semibold text-forest-900">
        What's included
      </h2>
      <ul class="mt-5 grid gap-3 sm:grid-cols-2">
        {
          service.highlights.map((h) => (
            <li class="flex items-start gap-3 rounded-2xl border border-forest-100 bg-white p-4">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-leaf-500/15 text-leaf-600">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <span class="text-sm text-forest-800">{h}</span>
            </li>
          ))
        }
      </ul>

      {
        service.faqs && service.faqs.length > 0 && (
          <div class="mt-14">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              {service.title} FAQs
            </h2>
            <div class="mt-5 space-y-3">
              {service.faqs.map((f) => (
                <details class="group rounded-2xl border border-forest-100 bg-white p-5 open:shadow-sm">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-forest-900">
                    {f.q}
                    <Icon name="chevron" class="h-5 w-5 shrink-0 text-forest-400 transition-transform group-open:rotate-180" />
                  </summary>
                  <p class="mt-3 leading-relaxed text-forest-700">{f.a}</p>
                </details>
              ))}
            </div>
          </div>
        )
      }

      <div class="mt-14">
        <h2 class="font-display text-2xl font-semibold text-forest-900">
          {service.title} across the Main Line
        </h2>
        <p class="mt-3 text-forest-700">
          We provide {service.title.toLowerCase()} throughout Montgomery County and the
          Main Line, including:
        </p>
        <ul class="mt-5 flex flex-wrap gap-2.5">
          {
            areaCities.map((ct) => (
              <li>
                <a
                  href={areaPath(ct.slug)}
                  class="block rounded-full border border-forest-200 bg-white px-4 py-1.5 text-sm font-medium text-forest-700 transition hover:border-leaf-500 hover:text-forest-900"
                >
                  {ct.name}
                </a>
              </li>
            ))
          }
        </ul>
        <a
          href="/service-areas/"
          class="mt-5 inline-flex items-center gap-1.5 font-display text-sm font-semibold tracking-wide text-leaf-600 hover:text-leaf-500"
        >
          View all service areas
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div>
          <h2 class="font-display text-xl font-semibold text-forest-900">
            Get a free estimate
          </h2>
          <p class="mt-2 text-sm text-forest-700">
            Tell us about your project and we'll get back to you fast.
          </p>
          <div class="mt-4">
            <LeadForm defaultService={`${catLabel}: ${service.title}`} compact />
          </div>
        </div>

        {
          related.length > 0 && (
            <div class="rounded-3xl border border-forest-100 bg-white p-7">
              <h3 class="font-semibold text-forest-900">More {catLabel.toLowerCase()} services</h3>
              <ul class="mt-4 space-y-1">
                {related.map((r) => (
                  <li>
                    <a
                      href={r.path}
                      class="group flex items-center justify-between rounded-xl px-3 py-2 text-sm text-forest-700 hover:bg-forest-50"
                    >
                      {r.title}
                      <Icon name="arrow" class="h-4 w-4 text-forest-300 transition-transform group-hover:translate-x-0.5 group-hover:text-clay-500" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }

        {
          otherCats.length > 0 && (
            <div class="rounded-3xl border border-forest-100 bg-white p-7">
              <h3 class="font-semibold text-forest-900">Explore more services</h3>
              <ul class="mt-4 space-y-1">
                {otherCats.map((cat) => (
                  <li>
                    <a
                      href={cat.href}
                      class="group flex items-center justify-between rounded-xl px-3 py-2 text-sm text-forest-700 hover:bg-forest-50"
                    >
                      {cat.label}
                      <Icon name="arrow" class="h-4 w-4 text-forest-300 transition-transform group-hover:translate-x-0.5 group-hover:text-clay-500" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </aside>
  </div>
</Section>

<ProcessSteps />
<CtaBanner />

<style>
  /* In-body contextual internal links (authored in src/data/services.ts).
     set:html content isn't reached by Astro's scoped selectors, so :global. */
  .body-copy :global(a) {
    font-weight: 600;
    color: var(--color-leaf-600);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .body-copy :global(a:hover) {
    color: var(--color-leaf-500);
  }
</style>
