---
import type { Service } from "../../data/services";
import { categoryLabels, categoryHubs, servicesByCategory } from "../../data/services";
import { seoFor } from "../../data/seo.generated";
import PageHero from "../PageHero.astro";
import Section from "../Section.astro";
import LeadForm from "../LeadForm.astro";
import CtaBanner from "../CtaBanner.astro";
import ProcessSteps from "../ProcessSteps.astro";
import Icon from "../Icon.astro";

interface Props {
  service: Service;
}
const { service } = Astro.props;
const meta = seoFor(service.path);
const h1 = meta?.h1 && meta.h1.length ? meta.h1 : service.title;
const catLabel = categoryLabels[service.category];
const hub = categoryHubs[service.category];
const related = servicesByCategory(service.category)
  .filter((s) => s.path !== service.path)
  .slice(0, 5);
---

<PageHero
  eyebrow={catLabel}
  title={h1}
  intro={service.intro}
  image={service.image}
  crumbs={[
    { label: "Home", href: "/" },
    { label: catLabel, href: hub },
    { label: service.title },
  ]}
/>

<Section>
  <div class="grid gap-12 lg:grid-cols-3">
    <div class="lg:col-span-2">
      {
        service.body.map((b) => (
          <div class="mb-8">
            <h2 class="font-display text-2xl font-semibold text-forest-900">
              {b.heading}
            </h2>
            <p class="mt-3 text-lg leading-relaxed text-forest-800">{b.text}</p>
          </div>
        ))
      }

      <h2 class="font-display mt-2 text-2xl font-semibold text-forest-900">
        What's included
      </h2>
      <ul class="mt-5 grid gap-3 sm:grid-cols-2">
        {
          service.highlights.map((h) => (
            <li class="flex items-start gap-3 rounded-2xl border border-forest-100 bg-white p-4">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-leaf-500/15 text-leaf-600">
                <Icon name="check" class="h-4 w-4" />
              </span>
              <span class="text-sm text-forest-800">{h}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 space-y-6">
        <div>
          <h2 class="font-display text-xl font-semibold text-forest-900">
            Get a free estimate
          </h2>
          <p class="mt-2 text-sm text-forest-700">
            Tell us about your project and we'll get back to you fast.
          </p>
          <div class="mt-4">
            <LeadForm defaultService={`${catLabel}: ${service.title}`} compact />
          </div>
        </div>

        {
          related.length > 0 && (
            <div class="rounded-3xl border border-forest-100 bg-white p-7">
              <h3 class="font-semibold text-forest-900">More {catLabel.toLowerCase()} services</h3>
              <ul class="mt-4 space-y-1">
                {related.map((r) => (
                  <li>
                    <a
                      href={r.path}
                      class="group flex items-center justify-between rounded-xl px-3 py-2 text-sm text-forest-700 hover:bg-forest-50"
                    >
                      {r.title}
                      <Icon name="arrow" class="h-4 w-4 text-forest-300 transition-transform group-hover:translate-x-0.5 group-hover:text-clay-500" />
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </div>
    </aside>
  </div>
</Section>

<ProcessSteps />
<CtaBanner />
