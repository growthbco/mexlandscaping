---
import { business } from "../data/site";
import Button from "./Button.astro";
import Icon from "./Icon.astro";

interface Props {
  title?: string;
  intro?: string;
}
const {
  title = "Ready to transform your property?",
  intro = "Get a free, no-obligation estimate. Tell us about your project and we'll put together a plan built around your goals and budget.",
} = Astro.props;
---

<section class="bg-forest-900">
  <div class="container-page py-16 lg:py-20">
    <div class="relative overflow-hidden rounded-3xl bg-forest-800 px-8 py-12 lg:px-14 lg:py-16">
      <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-leaf-500/20 blur-3xl"></div>
      <div class="relative flex flex-col items-start gap-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="max-w-2xl">
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-leaf-400">
            <span class="h-px w-6 bg-leaf-500"></span>Free estimate
          </span>
          <h2 class="mt-3 text-3xl font-semibold text-cream sm:text-4xl" style="font-family:var(--font-display)">
            {title}
          </h2>
          <p class="mt-4 text-lg text-forest-200">{intro}</p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:flex-row lg:flex-col">
          <Button href="/contact-us/" size="lg">Get a Free Estimate</Button>
          <a href={business.phoneHref} class="inline-flex items-center justify-center gap-2 rounded-full border border-forest-600 px-7 py-3.5 font-semibold text-cream hover:bg-forest-700">
            <Icon name="phone" class="h-5 w-5" />{business.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
