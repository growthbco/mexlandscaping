---
import { business } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  title?: string;
  intro?: string;
}
const {
  title = "Ready to transform your property?",
  intro = "Get a free, no-obligation estimate. Tell us about your project and we'll put together a plan built around your goals and budget.",
} = Astro.props;
---

<section class="bg-ink-900">
  <div class="container-page py-20 lg:py-24">
    <div class="max-w-2xl">
      <span class="block text-sm font-semibold uppercase tracking-eyebrow text-gold-300">Free estimate</span>
      <h2 class="mt-3 font-display text-4xl font-semibold leading-[1.05] text-white sm:text-5xl">
        {title}
      </h2>
      <p class="mt-5 text-lg text-white/75">{intro}</p>
      <div class="mt-9 flex flex-col gap-3 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-leaf-500 px-7 py-3.5 font-display text-base font-semibold tracking-wide text-white transition-colors hover:bg-leaf-600"
        >
          <Icon name="phone" class="h-5 w-5" />
          Call Now
        </a>
        <a
          href="/contact-us/"
          class="group inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/25 px-7 py-3.5 font-display text-base font-semibold tracking-wide text-white transition-colors hover:border-white/60"
        >
          Request Estimate
          <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
        </a>
      </div>
    </div>
  </div>
</section>
