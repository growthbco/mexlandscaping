---
import { WEB3FORMS_KEY, nav } from "../data/site";

interface Props {
  /** Pre-fills the "service" field, e.g. "Patios" or "Lawn Mowing: Wayne, PA" */
  defaultService?: string;
  compact?: boolean;
  /** "green" renders the solid green hero panel; "card" the white bordered card */
  theme?: "card" | "green";
}
const { defaultService = "", compact = false, theme = "card" } = Astro.props;

const green = theme === "green";

// Flatten the service menu into a select list.
const serviceGroups = nav.filter((n) => n.children);
const inputClass = green
  ? "w-full rounded-lg border-0 bg-white px-4 py-3 text-forest-900 placeholder:text-forest-400 focus:outline-none focus:ring-2 focus:ring-ink-900/30"
  : "w-full rounded-lg border border-forest-200 bg-white px-4 py-3 text-forest-900 placeholder:text-forest-400 focus:border-leaf-500 focus:outline-none focus:ring-2 focus:ring-leaf-500/20";
const labelClass = green
  ? "sr-only"
  : "mb-1.5 block text-sm font-medium text-forest-800";
---

<div
  class={green
    ? "rounded-2xl bg-leaf-500 p-6 shadow-2xl shadow-ink-950/40 ring-1 ring-white/25 sm:p-8"
    : "rounded-2xl border border-forest-100 bg-white p-6 shadow-sm sm:p-8"}
  data-leadform
>
  {
    green && (
      <div class="mb-6 text-center text-white">
        <h2 class="font-display text-2xl font-semibold tracking-wide sm:text-3xl">Get Your Free Estimate</h2>
        <p class="mt-2 text-sm text-white/85">Fill out the form below and we will get back to you within 24 hours.</p>
      </div>
    )
  }
  <form class="space-y-4" data-form action="https://api.web3forms.com/submit" method="POST">
    <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
    <input type="hidden" name="subject" value="New lead from mexlandscaping.com" />
    <input type="hidden" name="from_name" value="Mex Landscaping Website" />
    <!-- Honeypot -->
    <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

    <div class={`grid gap-4 ${compact ? "" : "sm:grid-cols-2"}`}>
      <label class="block">
        <span class={labelClass}>Full name</span>
        <input name="name" required class={inputClass} placeholder={green ? "Name*" : "Jane Doe"} />
      </label>
      <label class="block">
        <span class={labelClass}>Email</span>
        <input name="email" type="email" required class={inputClass} placeholder={green ? "Email*" : "you@example.com"} />
      </label>
      <label class="block">
        <span class={labelClass}>Phone</span>
        <input name="phone" type="tel" required class={inputClass} placeholder={green ? "Phone*" : "(484) 555-0123"} />
      </label>
      <label class="block">
        <span class={labelClass}>Property ZIP or town</span>
        <input name="zip" required class={inputClass} placeholder={green ? "Property ZIP or town*" : "e.g. 19401 or Norristown"} />
      </label>
      <label class="block">
        <span class={labelClass}>Service needed</span>
        <select name="service" class={inputClass}>
          <option value="" disabled selected={!defaultService}>Select a Service</option>
          {defaultService && <option value={defaultService} selected>{defaultService}</option>}
          {
            serviceGroups.map((group) => (
              <optgroup label={group.label}>
                {group.children!.map((c) => (
                  <option value={`${group.label}: ${c.label}`}>{c.label}</option>
                ))}
              </optgroup>
            ))
          }
          <option value="Other">Something else</option>
        </select>
      </label>
      <label class="block">
        <span class={labelClass}>Budget range</span>
        <select name="budget" required class={inputClass}>
          <option value="" disabled selected>{green ? "Budget range*" : "Select a budget range"}</option>
          <option value="5k to 15k">$5k - $15k</option>
          <option value="15k to 40k">$15k - $40k</option>
          <option value="40k to 100k">$40k - $100k</option>
          <option value="100k plus">$100k+</option>
          <option value="Not sure yet">Not sure yet</option>
        </select>
      </label>
      <label class="block">
        <span class={labelClass}>Project timeline</span>
        <select name="timeline" required class={inputClass}>
          <option value="" disabled selected>{green ? "Project timeline*" : "Select a timeline"}</option>
          <option value="As soon as possible">As soon as possible</option>
          <option value="1 to 3 months">1 to 3 months</option>
          <option value="3 to 6 months">3 to 6 months</option>
          <option value="Just exploring">Just exploring</option>
        </select>
      </label>
      <label class="block">
        <span class={labelClass}>Property type</span>
        <select name="property_type" required class={inputClass}>
          <option value="" disabled selected>{green ? "Property type*" : "Select property type"}</option>
          <option value="Residential">Residential</option>
          <option value="Commercial">Commercial</option>
        </select>
      </label>
    </div>

    <label class="block">
      <span class={labelClass}>Project details</span>
      <textarea
        name="message"
        rows={compact || green ? 3 : 5}
        class={inputClass}
        placeholder={green ? "Tell us about your project (optional)" : "Tell us a bit about your property and what you're looking to do..."}
      ></textarea>
    </label>

    <button
      type="submit"
      data-submit
      class={green
        ? "inline-flex w-full items-center justify-center gap-2 rounded-lg bg-leaf-700 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-ink-900 disabled:opacity-60"
        : "inline-flex w-full items-center justify-center gap-2 rounded-lg bg-leaf-500 px-7 py-3.5 font-semibold text-white transition-colors hover:bg-leaf-600 disabled:opacity-60 sm:w-auto"}
    >
      Get Your Free Estimate →
    </button>
    <p class={`text-center text-xs ${green ? "text-white/80" : "text-forest-500"}`}>
      Your information is secure. We will never share it with anyone.
    </p>
  </form>

  <div data-success class="hidden text-center">
    <span class={`mx-auto grid h-14 w-14 place-items-center rounded-full ${green ? "bg-white/20 text-white" : "bg-leaf-500/15 text-leaf-600"}`}>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="m5 12 5 5L20 7"/></svg>
    </span>
    <h3 class={`mt-5 font-display text-2xl font-semibold ${green ? "text-white" : "text-forest-900"}`}>Thanks, we got it!</h3>
    <p class={`mt-2 ${green ? "text-white/85" : "text-forest-600"}`}>A member of the Mex Landscaping team will reach out shortly to schedule your free estimate.</p>
  </div>
</div>

<script>
  document.querySelectorAll("[data-leadform]").forEach((root) => {
    const form = root.querySelector("[data-form]") as HTMLFormElement | null;
    const success = root.querySelector("[data-success]");
    const btn = root.querySelector("[data-submit]") as HTMLButtonElement | null;
    if (!form) return;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (btn) {
        btn.disabled = true;
        btn.textContent = "Sending…";
      }
      try {
        // Tag every submission with the page it came from, so leads are
        // differentiated by source (e.g. the King of Prussia page) even
        // though all forms share one Web3Forms key.
        const fd = new FormData(form);
        const pageName = document.title.replace(/\s*\|\s*Mex Landscaping.*$/i, "").trim();
        fd.set("subject", `New lead from ${pageName || location.pathname}`);
        fd.set("page", pageName || location.pathname);

        // Send to BOTH channels independently. The Telegram endpoint is our own
        // (not subject to the email provider's spam filter), so a lead is never
        // lost just because the email provider hiccups.
        const payload: Record<string, string> = {};
        fd.forEach((v, k) => { payload[k] = String(v); });
        const telegramOk = fetch("/api/notify-lead/", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        }).then((r) => r.ok).catch(() => false);
        const emailOk = fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: fd,
        }).then((r) => r.json()).then((d) => !!d.success).catch(() => false);

        const [tg, email] = await Promise.all([telegramOk, emailOk]);
        if (tg || email) {
          form.classList.add("hidden");
          success?.classList.remove("hidden");
          if (typeof (window as any).gtag === "function") {
            (window as any).gtag("event", "generate_lead", {
              event_category: "lead_form",
              event_label: pageName || location.pathname,
            });
          }
          (window as any).dataLayer = (window as any).dataLayer || [];
          (window as any).dataLayer.push({ event: "lead_submit", form_page: pageName || location.pathname });
          return;
        }
        throw new Error("Submission failed");
      } catch (err) {
        if (btn) {
          btn.disabled = false;
          btn.textContent = "Get Your Free Estimate →";
        }
        alert("Sorry, something went wrong. Please call us at (484) 261-6650.");
      }
    });
  });
</script>
