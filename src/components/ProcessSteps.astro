---
import { process } from "../data/site";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
---

<Section>
  <SectionHeading
    eyebrow="Simple process"
    title="How it works"
    intro="Getting started with Mex Landscaping is easy. Here's how we transform your outdoor space."
    center
  />
  <div class="mt-14 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    {
      process.map((p, i) => (
        <div class="relative text-center">
          {i < process.length - 1 && (
            <span class="absolute left-[calc(50%+3rem)] top-10 hidden w-[calc(100%-6rem)] border-t-2 border-dashed border-forest-200 lg:block" aria-hidden="true" />
          )}
          <div class="relative mx-auto h-20 w-20">
            <span class="grid h-20 w-20 place-items-center rounded-full bg-leaf-500/10 text-leaf-600">
              <Icon name={p.icon} class="h-8 w-8" />
            </span>
            <span class="absolute -right-1 -top-1 grid h-8 w-8 place-items-center rounded-full bg-leaf-500 font-display text-sm font-semibold text-white">
              {p.step}
            </span>
          </div>
          <h3 class="mt-5 font-display text-xl font-semibold text-forest-900">{p.title}</h3>
          <p class="mx-auto mt-2 max-w-xs text-forest-600">{p.body}</p>
        </div>
      ))
    }
  </div>
  <div class="mt-12 text-center">
    <Button href="/contact-us/" size="lg">Get Your Free Estimate</Button>
  </div>
</Section>
