---
import { process } from "../data/site";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
---

<Section muted>
  <SectionHeading
    eyebrow="How it works"
    title="A clear, three-phase process"
    intro="From the first conversation to the finishing touches, you'll always know the plan, the timeline, and what comes next."
  />
  <div class="mt-12 grid gap-6 md:grid-cols-3">
    {
      process.map((p) => (
        <div class="rounded-3xl border border-forest-100 bg-white p-7">
          <span class="text-5xl font-semibold text-forest-100" style="font-family:var(--font-display)">
            {p.step}
          </span>
          <h3 class="mt-3 text-xl font-semibold text-forest-900" style="font-family:var(--font-display)">
            {p.title}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-forest-700/90">{p.body}</p>
        </div>
      ))
    }
  </div>
</Section>
