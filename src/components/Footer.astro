---
import { business, nav, cities } from "../data/site";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
const columns = nav.filter((n) => n.children).slice(0, 2);
const topCities = cities.slice(0, 8);
// Main Line entity strip: the money towns, linked to their city pages.
const mainLineSlugs = ["villanova", "gladwyne", "bryn-mawr", "wayne", "radnor", "berwyn", "king-of-prussia"];
const mainLineCities = mainLineSlugs
  .map((slug) => cities.find((c) => c.slug === slug))
  .filter((c) => !!c);
---

<footer class="bg-ink-900 text-white/70">
  <div class="container-page py-14 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <a href="/" class="inline-block">
          <img
            src="/images/mex-landscaping-logo.png"
            alt="Mex Landscaping"
            width="358"
            height="255"
            class="h-16 w-auto"
            loading="lazy"
          />
        </a>
        <p class="mt-5 max-w-xs text-sm leading-relaxed">
          Design-build landscaping, hardscaping, and landscape construction for
          Norristown, Montgomery County, and the Main Line of Philadelphia.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a href={business.social.facebook} aria-label="Facebook" class="grid h-10 w-10 place-items-center rounded-full bg-white/10 text-white transition hover:bg-leaf-500">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M13.5 21v-7h2.4l.4-3h-2.8V9.1c0-.9.3-1.5 1.5-1.5h1.4V5c-.3 0-1.1-.1-2-.1-2 0-3.4 1.2-3.4 3.5V11H8.5v3H11v7h2.5Z"/></svg>
          </a>
          <a href={business.social.google} aria-label="Google" class="grid h-10 w-10 place-items-center rounded-full bg-white/10 text-white transition hover:bg-leaf-500">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M21.6 12.2c0-.7-.1-1.4-.2-2H12v3.9h5.4a4.6 4.6 0 0 1-2 3v2.5h3.2c1.9-1.7 3-4.3 3-7.4Z"/><path d="M12 22c2.7 0 5-.9 6.6-2.4l-3.2-2.5c-.9.6-2 1-3.4 1-2.6 0-4.8-1.8-5.6-4.1H3.1v2.6A10 10 0 0 0 12 22Z"/><path d="M6.4 14a6 6 0 0 1 0-3.9V7.5H3.1a10 10 0 0 0 0 9l3.3-2.5Z"/><path d="M12 6c1.5 0 2.8.5 3.8 1.5L18.6 5A10 10 0 0 0 3.1 7.5L6.4 10c.8-2.3 3-4 5.6-4Z"/></svg>
          </a>
          <a href={business.social.tiktok} aria-label="TikTok" class="grid h-10 w-10 place-items-center rounded-full bg-white/10 text-white transition hover:bg-leaf-500">
            <svg viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true"><path d="M16.6 3c.4 2 1.7 3.4 3.9 3.6v3c-1.5 0-2.8-.4-3.9-1.2v5.7c0 4.2-3.4 6.4-6.6 5.7-2.6-.6-4.4-3-4-5.8.4-3 3.1-4.9 6-4.4v3.1c-1.3-.4-2.5 0-3 1.2-.5 1.3.3 2.6 1.6 2.8 1.4.3 2.7-.7 2.7-2.3V3h3.3Z"/></svg>
          </a>
        </div>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:col-span-5">
        {
          columns.map((col) => (
            <div>
              <h3 class="font-display text-base font-semibold tracking-wide text-white">{col.label}</h3>
              <ul class="mt-4 space-y-2.5 text-sm">
                {col.children!.slice(0, 6).map((c) => (
                  <li>
                    <a href={c.href} class="transition hover:text-white">{c.label}</a>
                  </li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>

      <div class="lg:col-span-3">
        <h3 class="font-display text-base font-semibold tracking-wide text-white">Contact Us</h3>
        <div class="mt-4 space-y-4 text-sm">
          <a href={business.phoneHref} class="flex items-start gap-2.5 hover:text-white">
            <Icon name="phone" class="mt-0.5 h-4 w-4 shrink-0 text-gold-300" />
            <span>
              <span class="block font-semibold text-white">{business.phoneDisplay}</span>
              {business.hours}
            </span>
          </a>
          <a href={business.emailHref} class="flex items-center gap-2.5 hover:text-white">
            <Icon name="mail" class="h-4 w-4 shrink-0 text-gold-300" />{business.email}
          </a>
          <p class="flex items-start gap-2.5">
            <Icon name="pin" class="mt-0.5 h-4 w-4 shrink-0 text-gold-300" />
            <span>{business.address.street}<br />{business.address.city}, {business.address.state} {business.address.zip}</span>
          </p>
        </div>
        <div class="mt-5 border-t border-white/10 pt-4 text-sm">
          <span class="font-semibold text-white">Serving:</span>
          {topCities.map((c) => c.name).join(", ")}, and more
          <a href="/service-areas/" class="ml-1 font-semibold text-leaf-400 hover:text-leaf-500">See all areas →</a>
        </div>
      </div>
    </div>
  </div>

  <div class="border-t border-white/10 bg-ink-950">
    <div class="container-page py-4 text-center text-sm text-white/50">
      <span class="font-semibold text-white/80">The Main Line's design-build landscaping contractor</span>
      <span class="mx-2 hidden sm:inline" aria-hidden="true">·</span>
      <span class="mt-1 block sm:mt-0 sm:inline">
        {
          mainLineCities.map((c, i) => (
            <>
              {i > 0 && <span class="mx-1.5 text-white/25" aria-hidden="true">|</span>}
              <a href={`/landscape-design-hardscaping-in-${c.slug}-pa/`} class="hover:text-white">{c.name}</a>
            </>
          ))
        }
      </span>
    </div>
  </div>

  <div class="border-t border-white/10 bg-ink-950">
    <div class="container-page flex flex-col items-start justify-between gap-3 py-5 text-sm text-white/50 sm:flex-row sm:items-center">
      <p>© {year} {business.legalName}. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/privacy-policy/" class="hover:text-white">Privacy Policy</a>
        <a href="/terms-conditions/" class="hover:text-white">Terms of Service</a>
        <a href="/service-areas/" class="hover:text-white">Service Areas</a>
        <a href="/projects/" class="hover:text-white">Case Studies</a>
        <a href="/commercial-landscaping/" class="hover:text-white">Commercial</a>
      </div>
    </div>
  </div>
</footer>
