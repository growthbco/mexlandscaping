---
import { business, nav, cities } from "../data/site";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
const columns = nav.filter((n) => n.children).slice(0, 3);
const topCities = cities.slice(0, 12);
---

<footer class="bg-forest-900 text-forest-100">
  <div class="container-page py-14 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <a href="/" class="inline-flex items-center gap-2">
          <span class="grid h-9 w-9 place-items-center rounded-full bg-forest-700 text-cream">
            <Icon name="leaf" class="h-5 w-5" />
          </span>
          <span class="text-xl font-semibold text-cream" style="font-family:var(--font-display)">
            Mex Landscaping
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-forest-200">
          Reliable, year-round landscaping, snow management, and hardscape for
          homes and businesses across Norristown and the Main Line.
        </p>
        <div class="mt-6 space-y-3 text-sm">
          <a href={business.phoneHref} class="flex items-center gap-2.5 hover:text-clay-300">
            <Icon name="phone" class="h-4 w-4 text-leaf-400" />{business.phoneDisplay}
          </a>
          <a href={business.emailHref} class="flex items-center gap-2.5 hover:text-clay-300">
            <Icon name="mail" class="h-4 w-4 text-leaf-400" />{business.email}
          </a>
          <p class="flex items-center gap-2.5">
            <Icon name="pin" class="h-4 w-4 text-leaf-400" />
            {business.address.street}, {business.address.city}, {business.address.state} {business.address.zip}
          </p>
          <p class="flex items-center gap-2.5">
            <Icon name="clock" class="h-4 w-4 text-leaf-400" />{business.hours}
          </p>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
          {
            columns.map((col) => (
              <div>
                <h3 class="text-sm font-semibold text-cream">{col.label}</h3>
                <ul class="mt-3 space-y-2 text-sm text-forest-200">
                  {col.children!.slice(0, 6).map((c) => (
                    <li>
                      <a href={c.href} class="hover:text-clay-300">{c.label}</a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-sm font-semibold text-cream">Service Areas</h3>
        <ul class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 text-sm text-forest-200">
          {
            topCities.map((c) => (
              <li>
                <a href={`/landscape-design-hardscaping-in-${c.slug}-pa/`} class="hover:text-clay-300">
                  {c.name}
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/service-areas/" class="mt-3 inline-block text-sm font-semibold text-leaf-400 hover:text-clay-300">
          All service areas →
        </a>
      </div>
    </div>

    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-forest-800 pt-6 text-sm text-forest-300 sm:flex-row sm:items-center">
      <p>© {year} {business.name}. All rights reserved.</p>
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2">
        <a href="/about-us/" class="hover:text-clay-300">About</a>
        <a href="/contact-us/" class="hover:text-clay-300">Contact</a>
        <a href="/privacy-policy/" class="hover:text-clay-300">Privacy</a>
        <a href="/terms-conditions/" class="hover:text-clay-300">Terms</a>
        <span class="hidden text-forest-700 sm:inline">|</span>
        <a href={business.social.facebook} class="hover:text-clay-300">Facebook</a>
        <a href={business.social.google} class="hover:text-clay-300">Google</a>
        <a href={business.social.tiktok} class="hover:text-clay-300">TikTok</a>
      </div>
    </div>
  </div>
</footer>
