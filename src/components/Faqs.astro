---
import { faqs } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  heading?: string;
}
const { heading = "Frequently asked questions" } = Astro.props;
---

<div class="mx-auto max-w-3xl">
  <h2 class="text-3xl font-semibold text-forest-900 sm:text-4xl" style="font-family:var(--font-display)">
    {heading}
  </h2>
  <div class="mt-8 space-y-3">
    {
      faqs.map((f) => (
        <details class="group rounded-2xl border border-forest-100 bg-white p-5 open:shadow-sm">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-semibold text-forest-900">
            {f.q}
            <Icon name="chevron" class="h-5 w-5 shrink-0 text-forest-400 transition-transform group-open:rotate-180" />
          </summary>
          <p class="mt-3 text-forest-700">{f.a}</p>
        </details>
      ))
    }
  </div>
</div>
