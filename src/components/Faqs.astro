---
import { faqs } from "../data/site";
import Icon from "./Icon.astro";

interface Props {
  heading?: string;
}
const { heading = "Frequently asked questions" } = Astro.props;
---

<div class="mx-auto max-w-3xl">
  <h2 class="text-center font-display text-4xl font-semibold text-forest-900 sm:text-5xl">
    {heading}
  </h2>
  <div class="mt-10 space-y-4">
    {
      faqs.map((f) => (
        <details class="group rounded-xl border border-forest-100 bg-white px-6 py-5 shadow-sm open:shadow-md">
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold text-forest-900">
            {f.q}
            <span class="relative grid h-5 w-5 shrink-0 place-items-center text-leaf-600">
              <span class="absolute h-0.5 w-4 bg-current" />
              <span class="absolute h-4 w-0.5 bg-current transition-transform group-open:scale-y-0" />
            </span>
          </summary>
          <p class="mt-3 leading-relaxed text-forest-600">{f.a}</p>
        </details>
      ))
    }
  </div>
</div>
