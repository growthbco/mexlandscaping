---
interface Props {
  name:
    | "leaf"
    | "snow"
    | "stone"
    | "fence"
    | "phone"
    | "mail"
    | "pin"
    | "check"
    | "arrow"
    | "chevron"
    | "menu"
    | "close"
    | "clock"
    | "star";
  class?: string;
}
const { name, class: className = "h-5 w-5" } = Astro.props;

const paths: Record<string, string> = {
  leaf: "M11 20A7 7 0 0 1 4 13c0-3 2-6 8-9 0 0 1 6-1 10M4 21c2-5 5-8 9-10",
  snow: "M12 3v18M5 6l14 12M19 6 5 18M12 6.5 9.5 5M12 6.5 14.5 5M12 17.5 9.5 19M12 17.5 14.5 19",
  stone:
    "M3 9h18M3 15h18M3 9v6M21 9v6M3 9l3-3h12l3 3M9 9v6M15 9v6M6 15v3M18 15v3",
  fence: "M6 4 4 6v14M10 4 8 6v14M14 4l-2 2v14M18 4l-2 2v14M3 10h18M3 15h18",
  phone:
    "M5 4h4l2 5-2.5 1.5a11 11 0 0 0 5 5L15 13l5 2v4a1 1 0 0 1-1 1A16 16 0 0 1 4 5a1 1 0 0 1 1-1Z",
  mail: "M3 5h18v14H3zM3 7l9 6 9-6",
  pin: "M12 21s7-6.3 7-11a7 7 0 1 0-14 0c0 4.7 7 11 7 11Z",
  check: "m5 12 5 5L20 7",
  arrow: "M5 12h14M13 6l6 6-6 6",
  chevron: "m6 9 6 6 6-6",
  menu: "M4 6h16M4 12h16M4 18h16",
  close: "M6 6 18 18M18 6 6 18",
  clock: "M12 7v5l3 2",
  star: "",
};

const isPin = name === "pin";
const isClock = name === "clock";
const isStar = name === "star";
---

{
  isStar ? (
    <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
      <path d="m12 2 2.9 6.3 6.9.7-5.1 4.6 1.4 6.8L12 17.8 5.9 20.4l1.4-6.8L2.2 9l6.9-.7Z" />
    </svg>
  ) : (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      {isClock && <circle cx="12" cy="12" r="9" />}
      {isPin && <circle cx="12" cy="10" r="2.5" />}
      <path d={paths[name]} />
    </svg>
  )
}
