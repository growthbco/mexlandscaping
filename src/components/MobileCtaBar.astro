---
// Sticky mobile call-to-action bar (phones only). White bar with an outlined
// "Call Now" and a solid "Free Estimate" button.
import { business } from "./../data/site";
import Icon from "./Icon.astro";

interface Props {
  /** Where the estimate button points. Use "#estimate" on landing pages. */
  estimateHref?: string;
}
const { estimateHref = "/contact-us/" } = Astro.props;
---

<div class="fixed inset-x-0 bottom-0 z-50 flex gap-2 border-t border-forest-100 bg-white p-2 shadow-[0_-4px_16px_rgba(0,0,0,0.10)] sm:hidden">
  <a
    href={business.phoneHref}
    data-tel
    class="flex flex-1 items-center justify-center gap-2 rounded-lg border-2 border-forest-300 bg-white py-3 font-display font-semibold tracking-wide text-forest-800"
  >
    <Icon name="phone" class="h-5 w-5 text-leaf-600" />
    Call Now
  </a>
  <a
    href={estimateHref}
    class="flex flex-1 items-center justify-center gap-2 rounded-lg bg-leaf-500 py-3 font-display font-semibold tracking-wide text-white"
  >
    Free Estimate
    <Icon name="arrow" class="h-4 w-4" />
  </a>
</div>
