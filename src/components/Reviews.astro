---
import { reviews, business } from "../data/site";
import Section from "./Section.astro";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";
---

<Section muted>
  <SectionHeading eyebrow="Testimonials" title="What our customers say" center />
  <div class="mt-12 grid gap-6 lg:grid-cols-3">
    {
      reviews.map((t, i) => (
        <figure class={`flex flex-col rounded-2xl border p-7 shadow-sm ${i === 0 ? "border-leaf-500/20 bg-leaf-500/5" : "border-forest-100 bg-white"}`}>
          <div class="flex gap-0.5 text-clay-400">
            {[0, 1, 2, 3, 4].map(() => (
              <Icon name="star" class="h-4 w-4" />
            ))}
          </div>
          <blockquote class="mt-4 flex-1 leading-relaxed text-forest-700">“{t.quote}”</blockquote>
          <figcaption class="mt-6 flex items-center gap-3 border-t border-forest-100 pt-5">
            <span class="grid h-11 w-11 shrink-0 place-items-center rounded-full bg-leaf-500/15 font-display text-lg font-semibold text-leaf-600">
              {t.name.charAt(0)}
            </span>
            <span>
              <span class="block font-semibold text-forest-900">{t.name}</span>
              <span class="text-sm text-forest-500">{t.location}</span>
            </span>
          </figcaption>
        </figure>
      ))
    }
  </div>
  <div class="mt-10 text-center">
    <a href={business.social.google} class="inline-flex items-center gap-2 font-display text-base font-semibold tracking-wide text-leaf-600 hover:text-leaf-500">
      Read All Reviews
      <Icon name="arrow" class="h-4 w-4" />
    </a>
  </div>
</Section>
