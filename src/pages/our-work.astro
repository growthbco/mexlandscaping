---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/our-work/");
const title = meta?.title ?? "Our Work | Mex Landscaping | Norristown PA";
const description =
  meta?.description ??
  "See Mex Landscaping's work across the Main Line: landscape design, hardscaping, fire features, and outdoor living.";

const projects = [
  { src: "/images/fire-pit.webp", label: "Stone Fire Pit & Patio", area: "Outdoor Living", span: "lg:col-span-2 lg:row-span-2 aspect-square lg:aspect-auto" },
  { src: "/images/lighting.jpg", label: "Architectural Landscape Lighting", area: "Design & Build" },
  { src: "/images/patio.jpg", label: "Backyard Paver Patio", area: "Hardscaping" },
  { src: "/images/driveway.jpg", label: "Paver Driveway", area: "Hardscaping" },
  { src: "/images/walkway.jpg", label: "Walkway & Plantings", area: "Hardscaping" },
  { src: "/images/landscape-design.webp", label: "Front-Yard Redesign", area: "Design & Build" },
  { src: "/images/stone-wall.jpg", label: "Stone Retaining Wall", area: "Hardscaping" },
  { src: "/images/commercial.jpg", label: "Commercial Landscape", area: "Commercial" },
  { src: "/images/projects/p1.jpg", label: "Custom Project", area: "Design & Build" },
];
---

<BaseLayout title={title} description={description} path="/our-work/">
  <PageHero
    eyebrow="Portfolio"
    title="Our work speaks for itself"
    intro="A look at recent design-build, hardscape, and outdoor living projects across the Main Line. Every one starts with a plan and ends with a property the owner is proud of."
    image="/images/fire-pit.webp"
    crumbs={[{ label: "Home", href: "/" }, { label: "Our Work" }]}
  />

  <Section>
    <SectionHeading eyebrow="Recent projects" title="Designed, built, and finished by our crews" />
    <div class="mt-12 grid auto-rows-[220px] grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        projects.map((p) => (
          <figure class={`photo-card group relative overflow-hidden rounded-3xl ring-1 ring-black/5 ${p.span ?? ""}`}>
            <img src={p.src} alt={p.label} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950/85 via-ink-950/10 to-transparent"></div>
            <figcaption class="absolute bottom-0 left-0 p-5 text-cream">
              <span class="text-xs font-semibold uppercase tracking-eyebrow text-gold-300">{p.area}</span>
              <span class="mt-1 block font-display text-lg font-semibold">{p.label}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
    <p class="mt-8 text-sm text-forest-500">More photos available on request, and your project could be next.</p>
  </Section>

  <CtaBanner title="Picture your property next" />
</BaseLayout>
