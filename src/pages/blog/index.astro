---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Section from "../../components/Section.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import Icon from "../../components/Icon.astro";
import { posts } from "../../data/posts";
import { seoFor } from "../../data/seo.generated";

const meta = seoFor("/blog/");
const title = meta?.title ?? "Blog | Mex Landscaping | Norristown PA";
const description =
  meta?.description ??
  "Expert landscaping tips and services in Norristown, PA from the Mex Landscaping blog.";

const fmt = (iso: string) =>
  iso
    ? new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })
    : "";
---

<BaseLayout title={title} description={description} path="/blog/">
  <PageHero
    eyebrow="From the field"
    title="Tips, guides & seasonal advice"
    intro="Practical insights on caring for your landscape, planning a project, and getting the most from every season."
    crumbs={[{ label: "Home", href: "/" }, { label: "Blog" }]}
  />

  <Section>
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <a href={`/${post.slug}/`} class="group flex flex-col overflow-hidden rounded-3xl border border-forest-100 bg-white transition-shadow hover:shadow-xl hover:shadow-forest-900/10">
            <div class="flex h-40 items-end bg-gradient-to-br from-forest-600 to-forest-800 p-5">
              <span class="rounded-full bg-cream/90 px-3 py-1 text-xs font-semibold text-forest-800">Mex Landscaping</span>
            </div>
            <div class="flex flex-1 flex-col p-6">
              <time class="text-xs font-medium text-forest-500">{fmt(post.date)}</time>
              <h2 class="font-display mt-2 text-xl font-semibold leading-snug text-forest-900">{post.title}</h2>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-forest-700/90">{post.description}</p>
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-forest-700 group-hover:text-clay-600">
                Read more
                <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </Section>

  <CtaBanner />
</BaseLayout>
