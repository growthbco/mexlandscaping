---
import LandingLayout from "../../layouts/LandingLayout.astro";
import LeadForm from "../../components/LeadForm.astro";
import Icon from "../../components/Icon.astro";
import { landers, getLander } from "../../data/landers";
import { reviews, process, business } from "../../data/site";

export function getStaticPaths() {
  return landers.map((l) => ({ params: { slug: l.slug }, props: { lander: l } }));
}

const { lander } = Astro.props;
const path = `/lp/${lander.slug}/`;
const trustIcons: Record<string, string> = {
  "Licensed & Insured": "check",
  "Locally Owned": "pin",
  "5-Star Rated": "star",
  "Free Estimates": "leaf",
};
---

<LandingLayout title={lander.metaTitle} description={lander.metaDescription} path={path}>
  <!-- Hero with form above the fold -->
  <section class="relative isolate overflow-hidden bg-ink-950 text-white">
    <img src={lander.heroImage} alt="" aria-hidden="true" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="eager" />
    <div class="absolute inset-0 -z-10 bg-ink-950/70"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-950/85 via-ink-950/45 to-transparent"></div>

    <div class="container-page relative grid items-center gap-10 py-12 lg:grid-cols-[1fr_34rem] lg:gap-14 lg:py-16">
      <div>
        <h1 class="text-balance font-display text-4xl font-semibold leading-[1.05] sm:text-5xl lg:text-6xl">
          {lander.h1}
        </h1>
        <p class="mt-5 max-w-xl text-lg text-white/85">{lander.subhead}</p>
        <ul class="mt-7 grid max-w-xl gap-x-6 gap-y-3 sm:grid-cols-2">
          {lander.trust.map((t) => (
            <li class="flex items-center gap-2.5 font-medium">
              <span class="grid h-6 w-6 shrink-0 place-items-center rounded-full bg-clay-400 text-ink-950">
                <Icon name={trustIcons[t] ?? "check"} class="h-3.5 w-3.5" />
              </span>
              {t}
            </li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href={business.phoneHref} data-tel class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-7 py-3.5 font-bold text-ink-900 shadow-lg transition hover:bg-forest-50">
            <Icon name="phone" class="h-5 w-5 text-leaf-500" />
            {business.phoneDisplay}
          </a>
          <a href="#estimate" class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/30 px-7 py-3.5 font-display font-semibold tracking-wide text-white transition hover:border-white/60">
            Get a Free Estimate
            <Icon name="arrow" class="h-4 w-4" />
          </a>
        </div>
      </div>

      <div id="estimate" class="scroll-mt-24 lg:justify-self-end">
        <div class="w-full lg:w-[34rem]">
          <LeadForm theme="green" defaultService={lander.formService} />
        </div>
      </div>
    </div>
  </section>

  <!-- Trust bar -->
  <section class="border-b border-forest-100 bg-sand">
    <div class="container-page grid grid-cols-2 gap-4 py-6 text-center sm:grid-cols-4">
      {lander.trust.map((t) => (
        <div class="flex items-center justify-center gap-2 text-sm font-semibold text-forest-800">
          <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-leaf-500/15 text-leaf-600">
            <Icon name={trustIcons[t] ?? "check"} class="h-4 w-4" />
          </span>
          {t}
        </div>
      ))}
    </div>
  </section>

  <!-- Benefits -->
  <section class="bg-white">
    <div class="container-page py-16 lg:py-20">
      <div class="grid gap-6 md:grid-cols-3">
        {lander.benefits.map((b) => (
          <div class="rounded-2xl border border-forest-100 bg-white p-7 shadow-sm">
            <h3 class="font-display text-xl font-semibold text-forest-900">{b.title}</h3>
            <p class="mt-3 leading-relaxed text-forest-600">{b.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's included + gallery -->
  <section class="bg-sand">
    <div class="container-page grid items-center gap-12 py-16 lg:grid-cols-2 lg:py-20">
      <div>
        <h2 class="font-display text-3xl font-semibold text-forest-900 sm:text-4xl">What's included</h2>
        <ul class="mt-6 space-y-3.5">
          {lander.included.map((i) => (
            <li class="flex gap-3">
              <span class="mt-0.5 grid h-6 w-6 shrink-0 place-items-center rounded-full bg-leaf-500 text-white">
                <Icon name="check" class="h-3.5 w-3.5" />
              </span>
              <span class="text-forest-800">{i}</span>
            </li>
          ))}
        </ul>
        <a href="#estimate" class="mt-8 inline-flex items-center justify-center gap-2 rounded-lg bg-leaf-500 px-7 py-3.5 font-display font-semibold tracking-wide text-white transition hover:bg-leaf-600">
          Get My Free Estimate
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
      <div class="grid grid-cols-2 gap-4">
        {lander.gallery.map((g, i) => (
          <figure class={`photo-card overflow-hidden rounded-2xl ring-1 ring-black/5 ${i === 0 ? "col-span-2 aspect-[16/9]" : "aspect-square"}`}>
            <img src={g.src} alt={g.label} loading="lazy" class="h-full w-full object-cover" />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-white">
    <div class="container-page py-16 lg:py-20">
      <h2 class="text-center font-display text-3xl font-semibold text-forest-900 sm:text-4xl">What our customers say</h2>
      <div class="mt-10 grid gap-6 lg:grid-cols-3">
        {reviews.map((t) => (
          <figure class="flex flex-col rounded-2xl border border-forest-100 bg-white p-7 shadow-sm">
            <div class="flex gap-0.5 text-clay-400">
              {[0, 1, 2, 3, 4].map(() => <Icon name="star" class="h-4 w-4" />)}
            </div>
            <blockquote class="mt-4 flex-1 leading-relaxed text-forest-700">“{t.quote}”</blockquote>
            <figcaption class="mt-6 border-t border-forest-100 pt-4">
              <span class="block font-semibold text-forest-900">{t.name}</span>
              <span class="text-sm text-forest-500">{t.location}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="bg-sand">
    <div class="container-page py-16 lg:py-20">
      <h2 class="text-center font-display text-3xl font-semibold text-forest-900 sm:text-4xl">How it works</h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {process.map((p) => (
          <div class="text-center">
            <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-leaf-500/10 font-display text-xl font-semibold text-leaf-600">
              {p.step}
            </span>
            <h3 class="mt-4 font-display text-lg font-semibold text-forest-900">{p.title}</h3>
            <p class="mx-auto mt-2 max-w-xs text-sm text-forest-600">{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white">
    <div class="container-page py-16 lg:py-20">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-center font-display text-3xl font-semibold text-forest-900 sm:text-4xl">Frequently asked questions</h2>
        <div class="mt-10 space-y-4">
          {lander.faqs.map((f) => (
            <details class="group rounded-xl border border-forest-100 bg-white px-6 py-5 shadow-sm open:shadow-md">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-lg font-semibold text-forest-900">
                {f.q}
                <Icon name="chevron" class="h-5 w-5 shrink-0 text-forest-400 transition-transform group-open:rotate-180" />
              </summary>
              <p class="mt-3 leading-relaxed text-forest-600">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="bg-ink-900 text-white">
    <div class="container-page py-16 text-center lg:py-20">
      <h2 class="mx-auto max-w-2xl font-display text-3xl font-semibold sm:text-4xl">Ready to get started? Get your free estimate</h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-white/75">No pressure, no obligation. Tell us about your project and we will get right back to you.</p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href={business.phoneHref} data-tel class="inline-flex items-center justify-center gap-2 rounded-lg bg-leaf-500 px-7 py-3.5 font-display font-semibold tracking-wide text-white transition hover:bg-leaf-600">
          <Icon name="phone" class="h-5 w-5" />
          {business.phoneDisplay}
        </a>
        <a href="#estimate" class="inline-flex items-center justify-center gap-2 rounded-lg border-2 border-white/25 px-7 py-3.5 font-display font-semibold tracking-wide text-white transition hover:border-white/60">
          Request Estimate
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>
    </div>
  </section>
</LandingLayout>
