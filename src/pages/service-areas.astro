---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import CtaBanner from "../components/CtaBanner.astro";
import MapEmbed from "../components/MapEmbed.astro";
import Icon from "../components/Icon.astro";
import { cities } from "../data/site";
import { designPath, snowPath } from "../data/locations";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/service-areas/");
const title = meta?.title ?? "Service Areas | Mex Landscaping";
const description =
  meta?.description ??
  "Mex Landscaping serves Norristown, King of Prussia, and surrounding Main Line communities.";
---

<BaseLayout title={title} description={description} path="/service-areas/">
  <PageHero
    eyebrow="Where we work"
    title="Serving Norristown & the Main Line"
    intro="We provide year-round landscaping, snow management, and hardscape services across Norristown, King of Prussia, and the surrounding communities."
    crumbs={[{ label: "Home", href: "/" }, { label: "Service Areas" }]}
  />

  <Section>
    <SectionHeading
      eyebrow="Communities"
      title="Proudly local, wherever you are on the Main Line"
      intro="Don't see your town? Reach out. We serve many neighboring communities and are always happy to take a look."
    />
    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        cities.map((c) => (
          <div class="rounded-2xl border border-forest-100 bg-white p-5">
            <div class="flex items-center gap-3">
              <span class="grid h-10 w-10 place-items-center rounded-xl bg-forest-50 text-forest-700">
                <Icon name="pin" class="h-5 w-5" />
              </span>
              <span class="font-semibold text-forest-900">{c.name}, PA</span>
            </div>
            <div class="mt-3 flex flex-wrap gap-2 text-sm">
              <a href={designPath(c.slug)} class="rounded-full bg-leaf-500/10 px-3 py-1 font-medium text-leaf-600 hover:bg-leaf-500/20">Design &amp; Hardscaping</a>
              <a href={snowPath(c.slug)} class="rounded-full bg-forest-700/10 px-3 py-1 font-medium text-forest-700 hover:bg-forest-700/20">Snow Management</a>
            </div>
          </div>
        ))
      }
    </div>

    <div class="mt-14">
      <h2 class="font-display text-2xl font-semibold text-forest-900">Based in Norristown, PA</h2>
      <p class="mt-2 text-forest-700">Centrally located to serve Montgomery County and the Main Line.</p>
      <MapEmbed class="mt-6" />
    </div>
  </Section>

  <CtaBanner title="Serving your neighborhood" />
</BaseLayout>
