---
import BaseLayout from "../layouts/BaseLayout.astro";
import Button from "../components/Button.astro";
---

<BaseLayout
  title="Page Not Found | Mex Landscaping"
  description="The page you're looking for couldn't be found."
  noindex
>
  <section class="container-page flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <span class="font-display text-7xl font-semibold text-forest-200">404</span>
    <h1 class="font-display mt-4 text-3xl font-semibold text-forest-900">
      We couldn't find that page
    </h1>
    <p class="mt-3 max-w-md text-forest-700">
      The page you're looking for may have moved or no longer exists. Let's get
      you back on track.
    </p>
    <div class="mt-8 flex flex-col gap-3 sm:flex-row">
      <Button href="/">Back home</Button>
      <Button href="/contact-us/" variant="outline">Contact us</Button>
    </div>
  </section>
</BaseLayout>
