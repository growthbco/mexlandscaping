---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Section from "../../components/Section.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import Icon from "../../components/Icon.astro";
import { projects } from "../../data/projects";

const site = "https://www.mexlandscaping.com";
const title = "Project Case Studies | Mex Landscaping | Norristown PA";
const description =
  "Real Mex Landscaping projects, start to finish: retaining walls, drainage systems, commercial grounds, and turf installations across Norristown and the Main Line.";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "@id": `${site}/projects/#webpage`,
    url: `${site}/projects/`,
    name: "Project Case Studies",
    description,
    isPartOf: { "@id": `${site}/#website` },
    about: { "@id": `${site}/#business` },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
      { "@type": "ListItem", position: 2, name: "Projects", item: `${site}/projects/` },
    ],
  },
];
---

<BaseLayout title={title} description={description} path="/projects/" schema={schema}>
  <PageHero
    eyebrow="Case Studies"
    title="Projects, start to finish"
    intro="How we take a property from problem to finished space: the situation we walked into, how we built the solution, and what the owner ended up with."
    image={projects[0].photos[1]?.src ?? projects[0].photos[0].src}
    crumbs={[{ label: "Home", href: "/" }, { label: "Projects" }]}
  />

  <Section>
    <div class="grid gap-8 sm:grid-cols-2">
      {
        projects.map((p) => (
          <a
            href={`/projects/${p.slug}/`}
            class="group overflow-hidden rounded-2xl border border-forest-100 bg-white transition hover:border-leaf-500/40 hover:shadow-md"
          >
            <div class="relative">
              <img
                src={p.photos.find((ph) => ph.tag === "After")?.src ?? p.photos[0].src}
                alt={p.photos[0].alt}
                loading="lazy"
                decoding="async"
                class="aspect-[16/10] w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
              />
            </div>
            <div class="p-6">
              <h2 class="font-display text-xl font-semibold text-forest-900">{p.title}</h2>
              <p class="mt-2 text-sm leading-relaxed text-forest-700">{p.summary}</p>
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-leaf-600">
                Read the case study
                <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        ))
      }
    </div>
    <p class="mt-10 text-forest-700">
      Want the full photo gallery? See everything on
      <a href="/our-work/" class="font-semibold text-leaf-600 hover:text-leaf-500">Our Work</a>.
    </p>
  </Section>

  <CtaBanner title="Have a project like one of these?" />
</BaseLayout>
