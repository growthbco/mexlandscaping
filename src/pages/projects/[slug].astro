---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Section from "../../components/Section.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import LeadForm from "../../components/LeadForm.astro";
import Icon from "../../components/Icon.astro";
import { projects, type Project } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug }, props: { project: p } }));
}

const { project } = Astro.props as { project: Project };
const site = "https://www.mexlandscaping.com";
const path = `/projects/${project.slug}/`;
const title = `${project.title} | Project Case Study | Mex Landscaping`;
const description = project.summary;
const heroImage = project.photos.find((p) => p.tag === "After")?.src ?? project.photos[0].src;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: `${site}/` },
      { "@type": "ListItem", position: 2, name: "Projects", item: `${site}/projects/` },
      { "@type": "ListItem", position: 3, name: project.title, item: `${site}${path}` },
    ],
  },
  ...project.photos.map((p) => ({
    "@context": "https://schema.org",
    "@type": "ImageObject",
    contentUrl: `${site}${p.src}`,
    name: p.caption,
    description: p.alt,
    creator: { "@id": `${site}/#business` },
    representativeOfPage: p.src === heroImage,
  })),
];
---

<BaseLayout title={title} description={description} path={path} ogImage={`${site}${heroImage}`} schema={schema}>
  <PageHero
    eyebrow={`Case Study${project.location ? ` · ${project.location}` : ""}`}
    title={project.title}
    intro={project.summary}
    image={heroImage}
    crumbs={[
      { label: "Home", href: "/" },
      { label: "Projects", href: "/projects/" },
      { label: project.title },
    ]}
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="lg:col-span-2">
        <div class="grid gap-4 sm:grid-cols-2">
          {
            project.photos.map((p) => (
              <figure class="overflow-hidden rounded-2xl border border-forest-100 bg-white">
                <div class="relative">
                  <img
                    src={p.src}
                    alt={p.alt}
                    loading="lazy"
                    decoding="async"
                    class="aspect-[4/3] w-full object-cover"
                  />
                  {p.tag && (
                    <span class="absolute left-3 top-3 rounded-full bg-ink-950/80 px-3 py-1 text-xs font-bold uppercase tracking-wide text-white">
                      {p.tag}
                    </span>
                  )}
                </div>
                <figcaption class="px-4 py-3 text-sm text-forest-700">{p.caption}</figcaption>
              </figure>
            ))
          }
        </div>

        {
          project.sections.map((s) => (
            <div class="mt-10">
              <h2 class="font-display text-2xl font-semibold text-forest-900">{s.heading}</h2>
              <p class="mt-3 text-lg leading-relaxed text-forest-800">{s.text}</p>
            </div>
          ))
        }

        <div class="mt-12">
          <h2 class="font-display text-2xl font-semibold text-forest-900">Services on this project</h2>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {
              project.services.map((s) => (
                <a
                  href={s.href}
                  class="group flex items-center justify-between rounded-2xl border border-forest-100 bg-white px-5 py-3.5 text-forest-800 transition hover:border-leaf-500/40 hover:bg-forest-50"
                >
                  <span class="font-medium">{s.label}</span>
                  <Icon name="arrow" class="h-4 w-4 shrink-0 text-forest-300 transition-transform group-hover:translate-x-0.5 group-hover:text-leaf-600" />
                </a>
              ))
            }
          </div>
        </div>

        <p class="mt-10 text-forest-700">
          <a href="/projects/" class="font-semibold text-leaf-600 hover:text-leaf-500">← All case studies</a>
        </p>
      </div>

      <div>
        <div class="lg:sticky lg:top-24">
          <LeadForm defaultService={`Project like: ${project.title}`} compact />
        </div>
      </div>
    </div>
  </Section>

  <CtaBanner title="Want a result like this one?" />
</BaseLayout>
