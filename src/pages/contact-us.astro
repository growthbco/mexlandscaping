---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import LeadForm from "../components/LeadForm.astro";
import Icon from "../components/Icon.astro";
import { business, faqs } from "../data/site";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/contact-us/");
const title = meta?.title ?? "Contact Us | Mex Landscaping";
const description =
  meta?.description ??
  "Get in touch with Mex Landscaping in Norristown, PA. Call (484) 261-6650 for a free estimate.";

const contactItems = [
  { icon: "phone", label: "Phone", value: business.phoneDisplay, href: business.phoneHref },
  { icon: "mail", label: "Email", value: business.email, href: business.emailHref },
  {
    icon: "pin",
    label: "Address",
    value: `${business.address.street}, ${business.address.city}, ${business.address.state} ${business.address.zip}`,
  },
  { icon: "clock", label: "Hours", value: business.hours },
] as const;
---

<BaseLayout title={title} description={description} path="/contact-us/">
  <PageHero
    eyebrow="Get in touch"
    title="Let's talk about your project"
    intro="Tell us what you have in mind and we'll get back to you with a free, no-obligation estimate."
    crumbs={[{ label: "Home", href: "/" }, { label: "Contact Us" }]}
  />

  <section class="container-page py-16 lg:py-20">
    <div class="grid gap-12 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <h2 class="font-display text-2xl font-semibold text-forest-900">Reach us directly</h2>
        <p class="mt-3 text-forest-700">
          Prefer to talk? Call or email. We're happy to answer questions and
          schedule a time to visit your property.
        </p>
        <ul class="mt-8 space-y-5">
          {
            contactItems.map((item) => (
              <li>
                <a href={item.href ?? undefined} class={item.href ? "flex items-start gap-4 hover:opacity-80" : "flex items-start gap-4"}>
                  <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-forest-700 text-cream">
                    <Icon name={item.icon} class="h-5 w-5" />
                  </span>
                  <span>
                    <span class="block text-sm font-medium text-forest-500">{item.label}</span>
                    <span class="block font-semibold text-forest-900">{item.value}</span>
                  </span>
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-10 rounded-3xl border border-forest-100 bg-sand p-6">
          <h3 class="font-semibold text-forest-900">Common questions</h3>
          <dl class="mt-4 space-y-4">
            {
              faqs.slice(0, 3).map((f) => (
                <div>
                  <dt class="text-sm font-semibold text-forest-800">{f.q}</dt>
                  <dd class="mt-1 text-sm text-forest-700">{f.a}</dd>
                </div>
              ))
            }
          </dl>
        </div>
      </div>

      <div class="lg:col-span-3">
        <LeadForm />
      </div>
    </div>
  </section>
</BaseLayout>
