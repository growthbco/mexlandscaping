---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import LeadForm from "../components/LeadForm.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import WhyChoose from "../components/WhyChoose.astro";
import Reviews from "../components/Reviews.astro";
import Faqs from "../components/Faqs.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { cities, business } from "../data/site";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/")!;

const featured = [
  {
    label: "Landscape Design & Build",
    href: "/landscape-design/",
    image: "/images/curb-colonial.webp",
    blurb: "Complete redesigns, planting, lighting, and grading, designed and built by one team.",
    icon: "leaf",
  },
  {
    label: "Hardscaping",
    href: "/hardscape-services/",
    image: "/images/pergola-patio.webp",
    blurb: "Patios, walkways, walls, and driveways built on an engineered base to last decades.",
    icon: "stone",
  },
  {
    label: "Outdoor Living",
    href: "/outdoor-living/",
    image: "/images/firepit-lit.webp",
    blurb: "Fire features, outdoor kitchens, and water features that extend your season.",
    icon: "flame",
  },
  {
    label: "Split Rail Fencing",
    href: "/split-rail-fencing/",
    image: "/images/rail-fence.webp",
    blurb: "Classic post-and-rail fence lines, our specialty, set straight and built to last.",
    icon: "stone",
  },
  {
    label: "Landscape Lighting",
    href: "/landscape-lighting/",
    image: "/images/lighting-dusk.webp",
    blurb: "Low-voltage lighting that makes your home and landscape shine after dark.",
    icon: "light",
  },
  {
    label: "Snow Management",
    href: "/snow-management-services/",
    image: "/images/commercial-after.webp",
    blurb: "Reliable plowing, salting, and 24/7 storm response for homes and businesses.",
    icon: "snow",
  },
] as const;

const gallery = [
  { src: "/images/wall-stone-house.webp", label: "Fieldstone walls & entrance", span: "sm:col-span-2 sm:row-span-2" },
  { src: "/images/lighting-dusk.webp", label: "Landscape lighting" },
  { src: "/images/curb-colonial.webp", label: "Sculpted planting design" },
  { src: "/images/walkway-cobble.webp", label: "Walkway & cobble edging" },
  { src: "/images/wall-stone-after.webp", label: "Natural stone wall & steps" },
];

---

<BaseLayout
  title={meta.title}
  description={meta.description}
  path="/"
  preloadImage="/images/hero-sunset-house.webp"
>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-ink-950 text-white">
    <img
      src="/images/hero-sunset-house.webp"
      alt="Main Line home at sunset with sculpted evergreens, landscape lighting and manicured lawn by Mex Landscaping"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      width="1600"
      height="1200"
    />
    <div class="absolute inset-0 -z-10 bg-ink-950/35"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-950/80 via-ink-950/35 to-transparent"></div>

    <div class="container-page relative grid items-center gap-12 py-16 lg:grid-cols-[1fr_34rem] lg:gap-14 lg:py-20">
      <div class="animate-fade-up">
        <span class="block text-sm font-bold uppercase tracking-eyebrow text-gold-300">
          Landscape Design &amp; Build on the Main Line
        </span>
        <h1 class="mt-4 text-balance font-display text-5xl font-semibold leading-[1.02] sm:text-6xl lg:text-7xl">
          High-end landscape design &amp; build in Norristown, PA
        </h1>
        <p class="mt-5 max-w-xl text-lg text-white/85">
          Mex Landscaping designs and builds distinctive outdoor spaces, from
          landscape redesigns and patios to fire features and hardscaping, for fine
          homes across Norristown, the Main Line, and beyond.
        </p>
        <p class="mt-7 flex flex-wrap items-center gap-x-2.5 gap-y-1.5 text-[15px] font-medium text-white/90">
          <span>Licensed &amp; Insured</span>
          <span class="text-gold-300" aria-hidden="true">·</span>
          <span class="inline-flex items-center gap-1.5">
            <Icon name="star" class="h-4 w-4 text-gold-300" />
            4.9 on Google
          </span>
          <span class="text-gold-300" aria-hidden="true">·</span>
          <span>Free Estimates Within 24 Hours</span>
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a
            href={business.phoneHref}
            class="inline-flex items-center justify-center gap-2 rounded-lg bg-white px-7 py-3.5 font-bold text-ink-900 shadow-lg transition hover:bg-forest-50"
          >
            <Icon name="phone" class="h-5 w-5 text-leaf-500" />
            {business.phoneDisplay}
          </a>
          <Button href="/our-work/" size="lg" variant="outline-light" arrow={false}>View Our Work</Button>
        </div>
      </div>

      <div class="animate-fade-up lg:justify-self-end">
        <div class="w-full lg:w-[34rem]">
          <LeadForm theme="green" />
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps />

  <!-- Services -->
  <Section muted>
    <SectionHeading
      eyebrow="What we do"
      title="Our services"
      intro="From full landscape transformations to year-round maintenance and snow: one accountable team and one standard of craftsmanship."
      center
    />
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {featured.map((f) => (
        <div class="photo-card group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-black/5">
          <div class="relative overflow-hidden">
            <a href={f.href} class="block aspect-[16/10]">
              <img src={f.image} alt={f.label} loading="lazy" class="h-full w-full object-cover" />
            </a>
            <span class="absolute left-4 top-4 grid h-11 w-11 place-items-center rounded-full bg-white text-leaf-600 shadow-md">
              <Icon name={f.icon} class="h-5 w-5" />
            </span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-display text-xl font-semibold text-forest-900">
              <a href={f.href}>{f.label}</a>
            </h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-forest-600">{f.blurb}</p>
            <a href={f.href} class="mt-5 inline-flex items-center gap-1.5 font-semibold text-leaf-600 transition hover:text-leaf-500">
              View service
              <Icon name="arrow" class="h-4 w-4" />
            </a>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Signature work (dark gallery) -->
  <section class="bg-ink-900 text-white">
    <div class="container-page py-20 lg:py-24">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <span class="block text-sm font-semibold uppercase tracking-eyebrow text-gold-300">Our work</span>
          <h2 class="mt-3 font-display text-4xl font-semibold sm:text-5xl">Built across the Main Line</h2>
        </div>
        <a href="/our-work/" class="inline-flex items-center gap-2 font-display text-base font-semibold tracking-wide text-leaf-400 hover:text-white">
          See the Full Portfolio
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>

      <div class="mt-10 grid auto-rows-[180px] grid-cols-2 gap-4 sm:grid-cols-4">
        {gallery.map((g) => (
          <figure class={`photo-card group relative overflow-hidden rounded-xl ring-1 ring-white/10 ${g.span ?? ""}`}>
            <img src={g.src} alt={g.label} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950/70 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
            <figcaption class="absolute bottom-3 left-3 text-sm font-medium text-white opacity-0 transition-opacity group-hover:opacity-100">{g.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <WhyChoose />

  <!-- Outdoor living feature band -->
  <section class="relative isolate mt-8 overflow-hidden bg-ink-950 text-white">
    <img src="/images/turf-pool.webp" alt="Turf lawn and bluestone paving beside a pool by Mex Landscaping" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" />
    <div class="absolute inset-0 -z-10 bg-ink-950/70"></div>
    <div class="container-page relative py-24 lg:py-32">
      <div class="max-w-xl">
        <span class="block text-sm font-semibold uppercase tracking-eyebrow text-gold-300">Outdoor living</span>
        <h2 class="mt-4 font-display text-4xl font-semibold leading-[1.05] sm:text-5xl">Designed for the way you live outside</h2>
        <p class="mt-5 text-lg text-white/85">
          Fire pits, outdoor kitchens, water features, and the hardscape that
          ties them together: complete outdoor rooms built around how you'll
          actually use the space.
        </p>
        <div class="mt-8">
          <Button href="/outdoor-living/" size="lg">Explore Outdoor Living</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="bg-ink-900 text-white">
    <div class="container-page py-20 lg:py-24">
      <span class="block text-sm font-semibold uppercase tracking-eyebrow text-gold-300">Service areas</span>
      <h2 class="mt-3 max-w-2xl font-display text-4xl font-semibold leading-[1.05] sm:text-5xl">
        Proudly serving Montgomery County &amp; the Main Line
      </h2>
      <p class="mt-4 max-w-2xl text-lg text-white/75">
        Norristown, King of Prussia, and the surrounding communities: design,
        hardscape, and outdoor living.
      </p>
      <ul class="mt-10 flex flex-wrap gap-2.5">
        {cities.map((c) => (
          <li>
            <a href={`/landscape-design-hardscaping-in-${c.slug}-pa/`} class="block rounded-lg border border-white/15 px-4 py-2 text-sm font-medium text-white/85 transition hover:border-leaf-400 hover:text-white">
              {c.name}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <Reviews />

  <Section>
    <Faqs />
  </Section>

  <CtaBanner title="Ready to transform your property?" />
</BaseLayout>
