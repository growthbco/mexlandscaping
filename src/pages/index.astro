---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import Reviews from "../components/Reviews.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { cities } from "../data/site";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/")!;

const featured = [
  {
    label: "Landscape Design & Build",
    href: "/landscape-design/",
    image: "/images/landscape-design.webp",
    blurb: "Complete redesigns, planting, lighting, and grading — designed and built by one team.",
    icon: "leaf",
  },
  {
    label: "Hardscaping",
    href: "/hardscape-services/",
    image: "/images/patio.jpg",
    blurb: "Patios, walkways, walls, and driveways built on an engineered base to last decades.",
    icon: "stone",
  },
  {
    label: "Outdoor Living",
    href: "/outdoor-living/",
    image: "/images/fire-pit.webp",
    blurb: "Fire features, outdoor kitchens, and water features that extend your season.",
    icon: "flame",
  },
  {
    label: "Concrete & Masonry",
    href: "/concrete-masonry/",
    image: "/images/driveway.jpg",
    blurb: "Poured and stamped concrete, plus full masonry — the craft that endures.",
    icon: "brick",
  },
] as const;

const gallery = [
  { src: "/images/fire-pit.webp", label: "Fire feature & patio", span: "sm:col-span-2 sm:row-span-2" },
  { src: "/images/lighting.jpg", label: "Landscape lighting" },
  { src: "/images/patio.jpg", label: "Paver patio" },
  { src: "/images/walkway.jpg", label: "Walkway & plantings" },
  { src: "/images/driveway.jpg", label: "Paver driveway" },
];

const trust = [
  "Design–build under one roof",
  "Free, no-obligation estimates",
  "Licensed & insured",
];
const stats = [
  { value: "22+", label: "Communities served" },
  { value: "Design", label: "to build, one team" },
  { value: "5★", label: "Homeowner-rated" },
];
---

<BaseLayout title={meta.title} description={meta.description} path="/">
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-ink-950 text-cream">
    <img
      src="/images/lighting.jpg"
      alt="Dusk landscape lighting on a stone Main Line home built by Mex Landscaping"
      class="absolute inset-0 -z-10 h-full w-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-t from-ink-950 via-ink-950/80 to-ink-950/55"></div>
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-ink-950/80 to-transparent"></div>

    <div class="container-page relative flex min-h-[88vh] flex-col justify-center py-24 lg:py-32">
      <div class="max-w-2xl animate-fade-up">
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-eyebrow text-gold-300">
          <span class="h-px w-8 bg-gold-400"></span>
          Design · Build · Outdoor Living
        </span>
        <h1 class="mt-6 text-balance font-display text-5xl font-semibold leading-[1.03] sm:text-6xl lg:text-7xl">
          High-end landscape design &amp; build on the Main Line
        </h1>
        <p class="mt-6 max-w-xl text-lg text-cream/85">
          Mex Landscaping designs and builds distinctive outdoor spaces —
          landscape redesigns, patios, fire features, and hardscaping — for fine
          homes across Norristown, the Main Line, and beyond.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <Button href="/contact-us/" size="lg">Start your project</Button>
          <Button href="/our-work/" size="lg" variant="outline-light">View our work</Button>
        </div>
        <ul class="mt-10 flex flex-wrap gap-x-7 gap-y-2 text-sm text-cream/75">
          {trust.map((t) => (
            <li class="flex items-center gap-2">
              <Icon name="check" class="h-4 w-4 text-gold-300" />
              {t}
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="relative border-t border-white/10 bg-ink-950/60 backdrop-blur">
      <div class="container-page grid grid-cols-3 divide-x divide-white/10">
        {stats.map((s) => (
          <div class="px-4 py-6 text-center">
            <div class="font-display text-2xl font-semibold text-gold-300 sm:text-3xl">{s.value}</div>
            <div class="mt-1 text-xs text-cream/60 sm:text-sm">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Positioning intro -->
  <Section>
    <div class="grid items-end gap-8 lg:grid-cols-2">
      <SectionHeading
        eyebrow="What we do"
        title="A design-build firm for distinctive outdoor spaces"
      />
      <p class="text-lg leading-relaxed text-forest-700/90">
        We focus on the work that transforms a property — full landscape
        redesigns, custom hardscaping, fire features, and outdoor living. From
        the first sketch to the final stone, it's one accountable team and one
        standard of craftsmanship.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {featured.map((f) => (
        <a href={f.href} class="photo-card group relative flex aspect-[4/5] flex-col justify-end overflow-hidden rounded-3xl ring-1 ring-black/5">
          <img src={f.image} alt={f.label} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950/90 via-ink-950/30 to-transparent"></div>
          <div class="relative p-6 text-cream">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-white/10 text-gold-300 backdrop-blur">
              <Icon name={f.icon} class="h-5 w-5" />
            </span>
            <h3 class="mt-4 font-display text-xl font-semibold">{f.label}</h3>
            <p class="mt-1.5 text-sm text-cream/75">{f.blurb}</p>
            <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-gold-300">
              Explore
              <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
            </span>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <!-- Signature work (dark gallery) -->
  <section class="bg-ink-900 text-cream">
    <div class="container-page py-20 lg:py-24">
      <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-eyebrow text-gold-300">
            <span class="h-px w-6 bg-gold-400"></span>Signature work
          </span>
          <h2 class="mt-3 font-display text-3xl font-semibold sm:text-4xl">Built across the Main Line</h2>
        </div>
        <a href="/our-work/" class="inline-flex items-center gap-1.5 font-semibold text-gold-300 hover:text-gold-200">
          See the full portfolio
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>

      <div class="mt-10 grid auto-rows-[180px] grid-cols-2 gap-4 sm:grid-cols-4">
        {gallery.map((g) => (
          <figure class={`photo-card group relative overflow-hidden rounded-2xl ring-1 ring-white/10 ${g.span ?? ""}`}>
            <img src={g.src} alt={g.label} loading="lazy" class="absolute inset-0 h-full w-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-ink-950/70 to-transparent opacity-0 transition-opacity group-hover:opacity-100"></div>
            <figcaption class="absolute bottom-3 left-3 text-sm font-medium text-cream opacity-0 transition-opacity group-hover:opacity-100">{g.label}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Outdoor living feature band -->
  <section class="relative isolate overflow-hidden bg-ink-950 text-cream">
    <img src="/images/fire-pit.webp" alt="Custom stone fire pit and patio at dusk" class="absolute inset-0 -z-10 h-full w-full object-cover" loading="lazy" />
    <div class="absolute inset-0 -z-10 bg-ink-950/70"></div>
    <div class="container-page relative py-24 lg:py-32">
      <div class="max-w-xl">
        <span class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-eyebrow text-gold-300">
          <span class="h-px w-6 bg-gold-400"></span>Outdoor living
        </span>
        <h2 class="mt-4 font-display text-4xl font-semibold leading-tight sm:text-5xl">Designed for the way you live outside</h2>
        <p class="mt-5 text-lg text-cream/85">
          Fire pits, outdoor kitchens, water features, and the hardscape that
          ties them together — complete outdoor rooms built around how you'll
          actually use the space.
        </p>
        <div class="mt-8">
          <Button href="/outdoor-living/" size="lg">Explore outdoor living</Button>
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps />

  <!-- Service areas -->
  <Section muted>
    <SectionHeading
      eyebrow="Where we work"
      title="Premium landscaping across the Main Line"
      intro="Norristown, King of Prussia, and the surrounding communities — design, hardscape, and outdoor living."
    />
    <ul class="mt-10 flex flex-wrap gap-2.5">
      {cities.map((c) => (
        <li>
          <a href={`/landscape-design-hardscaping-in-${c.slug}-pa/`} class="block rounded-full border border-forest-200 bg-white px-4 py-1.5 text-sm font-medium text-forest-700 hover:border-forest-400 hover:text-forest-900">
            {c.name}
          </a>
        </li>
      ))}
    </ul>
  </Section>

  <Reviews />
  <CtaBanner title="Let's design something exceptional" />
</BaseLayout>
