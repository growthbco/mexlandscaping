---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import SectionHeading from "../components/SectionHeading.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import WhyChoose from "../components/WhyChoose.astro";
import Reviews from "../components/Reviews.astro";
import CtaBanner from "../components/CtaBanner.astro";
import { categoryLabels, categoryHubs, servicesByCategory } from "../data/services";
import { cities } from "../data/site";
import { seoFor } from "../data/seo.generated";

const meta = seoFor("/")!;
const cats = (["landscaping", "snow", "hardscape"] as const).map((key) => ({
  key,
  label: categoryLabels[key],
  hub: categoryHubs[key],
  items: servicesByCategory(key),
}));
const icons = { landscaping: "leaf", snow: "snow", hardscape: "stone" } as const;
const heroPoints = [
  "Free, no-obligation estimates",
  "Residential & commercial",
  "Licensed & insured",
];
const stats = [
  { value: "22+", label: "Communities served" },
  { value: "24/7", label: "Winter snow response" },
  { value: "4", label: "Seasons of care" },
];
---

<BaseLayout title={meta.title} description={meta.description} path="/">
  <!-- Hero -->
  <section class="relative overflow-hidden bg-forest-900 text-cream">
    <div
      class="pointer-events-none absolute inset-0 opacity-90"
      style="background: radial-gradient(120% 90% at 80% -10%, #316038 0%, transparent 55%), radial-gradient(90% 80% at 0% 110%, #1c3321 0%, transparent 60%)"
    >
    </div>
    <div class="pointer-events-none absolute -right-24 top-1/3 h-96 w-96 rounded-full bg-leaf-500/20 blur-3xl"></div>
    <div class="container-page relative grid items-center gap-12 py-20 lg:grid-cols-2 lg:py-28">
      <div class="animate-fade-up">
        <span class="inline-flex items-center gap-2 rounded-full border border-forest-600 bg-forest-800/60 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-leaf-400">
          Proficient · Experienced · Reliable
        </span>
        <h1 class="mt-6 text-4xl font-semibold leading-[1.08] sm:text-5xl lg:text-6xl" style="font-family:var(--font-display)">
          Expert Landscaping, Snow Management &amp; Hardscape in Norristown, PA
        </h1>
        <p class="mt-6 max-w-xl text-lg text-forest-200">
          Transform your outdoor space with reliable, year-round solutions from
          the trusted professionals at Mex Landscaping.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href="/contact-us/" size="lg">Get a Free Estimate</Button>
          <Button href="/landscaping-services-in-norristown-pa/" size="lg" variant="outline-light">
            Explore our services
          </Button>
        </div>
        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2 text-sm text-forest-200">
          {
            heroPoints.map((point) => (
              <li class="flex items-center gap-2">
                <Icon name="check" class="h-4 w-4 text-leaf-400" />
                {point}
              </li>
            ))
          }
        </ul>
      </div>

      <div class="relative animate-fade-up lg:justify-self-end">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <div class="flex h-44 items-end rounded-3xl bg-gradient-to-br from-leaf-500 to-forest-700 p-5 text-sm font-semibold text-white shadow-lg ring-1 ring-white/10">Lush, healthy lawns</div>
            <div class="flex h-56 items-end rounded-3xl bg-gradient-to-br from-forest-600 to-forest-800 p-5 text-sm font-semibold text-white shadow-lg ring-1 ring-white/10">Custom patios &amp; stonework</div>
          </div>
          <div class="space-y-4 pt-8">
            <div class="flex h-56 items-end rounded-3xl bg-gradient-to-br from-clay-400 to-clay-600 p-5 text-sm font-semibold text-white shadow-lg ring-1 ring-white/10">Hardscape that lasts</div>
            <div class="flex h-44 items-end rounded-3xl bg-gradient-to-br from-forest-500 to-forest-700 p-5 text-sm font-semibold text-white shadow-lg ring-1 ring-white/10">Reliable snow response</div>
          </div>
        </div>
      </div>
    </div>

    <div class="relative border-t border-forest-800/80 bg-forest-950/40">
      <div class="container-page grid grid-cols-3 divide-x divide-forest-800/80">
        {
          stats.map((s) => (
            <div class="px-4 py-6 text-center">
              <div class="text-3xl font-semibold text-cream sm:text-4xl" style="font-family:var(--font-display)">{s.value}</div>
              <div class="mt-1 text-xs text-forest-300 sm:text-sm">{s.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Services -->
  <Section>
    <SectionHeading
      eyebrow="What we do"
      title="One trusted team for every season"
      intro="From design and planting to patios and winter snow response — we handle the full life of your property so it looks its best year-round."
    />
    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {
        cats.map((cat) => (
          <a href={cat.hub} class="group flex flex-col rounded-3xl border border-forest-100 bg-white p-7 transition-shadow hover:shadow-xl hover:shadow-forest-900/10">
            <div class="flex items-start justify-between">
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-forest-700 text-cream">
                <Icon name={icons[cat.key]} class="h-6 w-6" />
              </span>
              <Icon name="arrow" class="h-5 w-5 text-forest-300 transition-transform group-hover:translate-x-1 group-hover:text-clay-500" />
            </div>
            <h3 class="mt-5 text-2xl font-semibold text-forest-900" style="font-family:var(--font-display)">{cat.label}</h3>
            <ul class="mt-4 flex flex-wrap gap-2">
              {cat.items.slice(0, 5).map((item) => (
                <li class="rounded-full bg-forest-50 px-3 py-1 text-xs font-medium text-forest-700">{item.title}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </Section>

  <ProcessSteps />
  <WhyChoose />

  <!-- Service areas strip -->
  <section class="bg-sand">
    <div class="container-page py-12">
      <div class="flex flex-col items-center gap-4 text-center">
        <p class="text-sm font-semibold uppercase tracking-[0.16em] text-leaf-600">Proudly serving the Main Line</p>
        <ul class="flex flex-wrap justify-center gap-2.5">
          {
            cities.slice(0, 14).map((c) => (
              <li>
                <a href={`/lawn-mowing-services-in-${c.slug}-pa/`} class="block rounded-full border border-forest-200 bg-white px-4 py-1.5 text-sm font-medium text-forest-700 hover:border-forest-400">
                  {c.name}
                </a>
              </li>
            ))
          }
        </ul>
        <a href="/service-areas/" class="mt-2 font-semibold text-forest-700 hover:text-clay-600">See all service areas →</a>
      </div>
    </div>
  </section>

  <Reviews />
  <CtaBanner />
</BaseLayout>
