---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { business } from "../data/site";

interface Props {
  title: string;
  description: string;
  /** Path of the current page, e.g. "/patios/". Defaults to Astro.url.pathname */
  path?: string;
  ogImage?: string;
  /** Extra JSON-LD objects to inject (Service, BreadcrumbList, Article, etc.) */
  schema?: object[];
  noindex?: boolean;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogImage,
  schema = [],
  noindex = false,
} = Astro.props;

const site = "https://www.mexlandscaping.com";
const canonical = new URL(path, site).href;
const image = ogImage && ogImage.length ? ogImage : `${site}/og-default.svg`;

// LocalBusiness schema rendered site-wide.
const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LandscapingBusiness",
  "@id": `${site}/#business`,
  name: business.name,
  legalName: business.legalName,
  url: site,
  telephone: business.phone,
  email: business.email,
  priceRange: business.priceRange,
  image,
  address: {
    "@type": "PostalAddress",
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.state,
    postalCode: business.address.zip,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: business.geo.lat,
    longitude: business.geo.lng,
  },
  areaServed: "Montgomery County & the Main Line, PA",
  sameAs: [business.social.facebook, business.social.google, business.social.tiktok],
};

const allSchema = [localBusiness, ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..700&family=Inter:wght@400..700&display=swap"
      rel="stylesheet"
    />

    {
      allSchema.map((s) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(s)}
          is:inline
        />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
