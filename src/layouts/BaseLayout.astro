---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import MobileCtaBar from "../components/MobileCtaBar.astro";
import { business } from "../data/site";

interface Props {
  title: string;
  description: string;
  /** Path of the current page, e.g. "/patios/". Defaults to Astro.url.pathname */
  path?: string;
  ogImage?: string;
  /** Extra JSON-LD objects to inject (Service, BreadcrumbList, Article, etc.) */
  schema?: object[];
  noindex?: boolean;
  /** Above-the-fold hero image to preload at high priority (LCP) */
  preloadImage?: string;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  ogImage,
  schema = [],
  noindex = false,
  preloadImage,
} = Astro.props;

const site = "https://www.mexlandscaping.com";
const canonical = new URL(path, site).href;
// Ignore legacy WordPress /wp-content/ image URLs (they 404 on the new site)
// and fall back to a real 1200x630 raster share image.
const cleanOg = ogImage && !ogImage.includes("/wp-content/") ? ogImage : "";
const image = cleanOg.length ? cleanOg : `${site}/images/og-default.jpg`;

// LocalBusiness schema rendered site-wide.
const localBusiness = {
  "@context": "https://schema.org",
  "@type": "LandscapingBusiness",
  "@id": `${site}/#business`,
  name: business.name,
  legalName: business.legalName,
  url: site,
  // E.164 format (Google's preferred telephone format for LocalBusiness).
  telephone: business.phoneHref.replace("tel:", ""),
  email: business.email,
  priceRange: business.priceRange,
  image,
  address: {
    "@type": "PostalAddress",
    streetAddress: business.address.street,
    addressLocality: business.address.city,
    addressRegion: business.address.state,
    postalCode: business.address.zip,
    addressCountry: "US",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: business.geo.lat,
    longitude: business.geo.lng,
  },
  hasMap: business.social.google,
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "07:00",
      closes: "18:00",
    },
  ],
  areaServed: [
    { "@type": "AdministrativeArea", name: "Montgomery County, PA" },
    { "@type": "AdministrativeArea", name: "The Main Line, PA" },
    { "@type": "AdministrativeArea", name: "Delaware County, PA" },
  ],
  sameAs: [business.social.facebook, business.social.google, business.social.tiktok],
};

const webSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${site}/#website`,
  name: business.name,
  url: site,
  publisher: { "@id": `${site}/#business` },
};

const allSchema = [localBusiness, webSite, ...schema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5CFHNLJV');</script>
    <!-- End Google Tag Manager -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CRXNSCNB4M" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CRXNSCNB4M');
    </script>

    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Fonts: loaded async so the third-party CSS request never blocks first paint -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400..700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400..700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    {
      allSchema.map((s) => (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(s)}
          is:inline
        />
      ))
    }
  </head>
  <body class="flex min-h-screen flex-col pb-16 sm:pb-0">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5CFHNLJV" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <MobileCtaBar />
    <script is:inline>
      // Push a dataLayer event on any click-to-call so GTM can fire a
      // Google Ads call conversion.
      document.querySelectorAll('a[href^="tel:"]').forEach(function (el) {
        el.addEventListener('click', function () {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event: 'phone_click', form_page: document.title });
        });
      });
    </script>
  </body>
</html>
